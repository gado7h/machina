          <Item class="ModuleScript" referent="26">
            <Properties>
              <string name="Name">FirmwareRom</string>
              <string name="Source"><![CDATA[-- FirmwareRom module

local FirmwareRom = {}
FirmwareRom.__index = FirmwareRom

function FirmwareRom.new(config)
	local self = setmetatable({}, FirmwareRom)
	self.config = config
	self.size = config.ROM_SIZE or 0
	self._data = {} -- offset â†’ byte
	self._locked = true -- write-protected by default
	self._unlockSeq = { 0xAA, 0x55, 0xA0 } -- must write to 0x5555, 0x2AAA, 0x5555
	self._unlockStep = 0
	self.stats = { reads = 0, writeAttempts = 0, programOps = 0 }
	return self
end

--- Load a firmware image (table of bytes) into FirmwareRom.
--- Called by the system builder before powering on.
function FirmwareRom:flash(bytes)
	self._locked = false
	for i, b in ipairs(bytes) do
		self._data[i - 1] = b % 256
	end
	self._locked = true
	self.stats.programOps = self.stats.programOps + 1
end

--- Load a firmware image from a Lua string.
function FirmwareRom:flashString(str)
	local bytes = {}
	for i = 1, #str do
		bytes[i] = string.byte(str, i)
	end
	self:flash(bytes)
end

function FirmwareRom:memRead(offset)
	self.stats.reads = self.stats.reads + 1
	return self._data[offset] or 0xFF -- unprogrammed NOR = 0xFF
end

function FirmwareRom:memWrite(offset, value)
	self.stats.writeAttempts = self.stats.writeAttempts + 1
	-- Implement AMD/SST-style unlock sequence for flash programming
	if self._locked then
		return
	end -- silently ignore when locked
	self._data[offset] = value % 256
end

function FirmwareRom:readRegion(offset, length)
	local out = {}
	for i = 0, length - 1 do
		table.insert(out, self._data[offset + i] or 0xFF)
	end
	return out
end

--- Dump FirmwareRom contents as hex string for debugging.
function FirmwareRom:hexDump(offset, length)
	local lines = {}
	local line = {}
	for i = 0, length - 1 do
		table.insert(line, string.format("%02X", self._data[offset + i] or 0xFF))
		if #line == 16 then
			table.insert(lines, string.format("%04X: %s", offset + i - 15, table.concat(line, " ")))
			line = {}
		end
	end
	if #line > 0 then
		table.insert(lines, string.format("%04X: %s", offset + length - #line, table.concat(line, " ")))
	end
	return lines
end

function FirmwareRom:getStats()
	return self.stats
end
function FirmwareRom:getSize()
	return self.size
end

return FirmwareRom
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="27">
            <Properties>
              <string name="Name">I8042Controller</string>
              <string name="Source"><![CDATA[local I8042Controller = {}
I8042Controller.__index = I8042Controller

local KBD_ACK = 0xFA
local KBD_SELF_TEST_PASSED = 0xAA

local STATUS_OUTPUT_FULL = 0x01
local STATUS_INPUT_FULL = 0x02
local STATUS_SYSTEM = 0x04
local STATUS_COMMAND = 0x08

local COMMAND_IRQ1_ENABLE = 0x01
local COMMAND_SYSTEM_FLAG = 0x04
local COMMAND_DISABLE_KEYBOARD = 0x10

local SCAN_MAKE = {
	[Enum.KeyCode.A] = 0x1E,
	[Enum.KeyCode.B] = 0x30,
	[Enum.KeyCode.C] = 0x2E,
	[Enum.KeyCode.D] = 0x20,
	[Enum.KeyCode.E] = 0x12,
	[Enum.KeyCode.F] = 0x21,
	[Enum.KeyCode.G] = 0x22,
	[Enum.KeyCode.H] = 0x23,
	[Enum.KeyCode.I] = 0x17,
	[Enum.KeyCode.J] = 0x24,
	[Enum.KeyCode.K] = 0x25,
	[Enum.KeyCode.L] = 0x26,
	[Enum.KeyCode.M] = 0x32,
	[Enum.KeyCode.N] = 0x31,
	[Enum.KeyCode.O] = 0x18,
	[Enum.KeyCode.P] = 0x19,
	[Enum.KeyCode.Q] = 0x10,
	[Enum.KeyCode.R] = 0x13,
	[Enum.KeyCode.S] = 0x1F,
	[Enum.KeyCode.T] = 0x14,
	[Enum.KeyCode.U] = 0x16,
	[Enum.KeyCode.V] = 0x2F,
	[Enum.KeyCode.W] = 0x11,
	[Enum.KeyCode.X] = 0x2D,
	[Enum.KeyCode.Y] = 0x15,
	[Enum.KeyCode.Z] = 0x2C,
	[Enum.KeyCode.Zero] = 0x0B,
	[Enum.KeyCode.One] = 0x02,
	[Enum.KeyCode.Two] = 0x03,
	[Enum.KeyCode.Three] = 0x04,
	[Enum.KeyCode.Four] = 0x05,
	[Enum.KeyCode.Five] = 0x06,
	[Enum.KeyCode.Six] = 0x07,
	[Enum.KeyCode.Seven] = 0x08,
	[Enum.KeyCode.Eight] = 0x09,
	[Enum.KeyCode.Nine] = 0x0A,
	[Enum.KeyCode.Return] = 0x1C,
	[Enum.KeyCode.Space] = 0x39,
	[Enum.KeyCode.Backspace] = 0x0E,
	[Enum.KeyCode.Tab] = 0x0F,
	[Enum.KeyCode.Escape] = 0x01,
	[Enum.KeyCode.LeftShift] = 0x2A,
	[Enum.KeyCode.RightShift] = 0x36,
	[Enum.KeyCode.LeftControl] = 0x1D,
	[Enum.KeyCode.RightControl] = { 0xE0, 0x1D },
	[Enum.KeyCode.LeftAlt] = 0x38,
	[Enum.KeyCode.RightAlt] = { 0xE0, 0x38 },
	[Enum.KeyCode.CapsLock] = 0x3A,
	[Enum.KeyCode.F1] = 0x3B,
	[Enum.KeyCode.F2] = 0x3C,
	[Enum.KeyCode.F3] = 0x3D,
	[Enum.KeyCode.F4] = 0x3E,
	[Enum.KeyCode.F5] = 0x3F,
	[Enum.KeyCode.F6] = 0x40,
	[Enum.KeyCode.F7] = 0x41,
	[Enum.KeyCode.F8] = 0x42,
	[Enum.KeyCode.F9] = 0x43,
	[Enum.KeyCode.F10] = 0x44,
	[Enum.KeyCode.F11] = 0x57,
	[Enum.KeyCode.F12] = 0x58,
	[Enum.KeyCode.Up] = { 0xE0, 0x48 },
	[Enum.KeyCode.Down] = { 0xE0, 0x50 },
	[Enum.KeyCode.Left] = { 0xE0, 0x4B },
	[Enum.KeyCode.Right] = { 0xE0, 0x4D },
	[Enum.KeyCode.Delete] = { 0xE0, 0x53 },
	[Enum.KeyCode.Insert] = { 0xE0, 0x52 },
	[Enum.KeyCode.Home] = { 0xE0, 0x47 },
	[Enum.KeyCode.End] = { 0xE0, 0x4F },
	[Enum.KeyCode.PageUp] = { 0xE0, 0x49 },
	[Enum.KeyCode.PageDown] = { 0xE0, 0x51 },
	[Enum.KeyCode.Minus] = 0x0C,
	[Enum.KeyCode.Equals] = 0x0D,
	[Enum.KeyCode.LeftBracket] = 0x1A,
	[Enum.KeyCode.RightBracket] = 0x1B,
	[Enum.KeyCode.Semicolon] = 0x27,
	[Enum.KeyCode.Quote] = 0x28,
	[Enum.KeyCode.Backquote] = 0x29,
	[Enum.KeyCode.BackSlash] = 0x2B,
	[Enum.KeyCode.Comma] = 0x33,
	[Enum.KeyCode.Period] = 0x34,
	[Enum.KeyCode.Slash] = 0x35,
}

local SC_TO_ASCII_LOWER = {
	[0x02] = "1",
	[0x03] = "2",
	[0x04] = "3",
	[0x05] = "4",
	[0x06] = "5",
	[0x07] = "6",
	[0x08] = "7",
	[0x09] = "8",
	[0x0A] = "9",
	[0x0B] = "0",
	[0x0C] = "-",
	[0x0D] = "=",
	[0x0E] = "\b",
	[0x0F] = "\t",
	[0x10] = "q",
	[0x11] = "w",
	[0x12] = "e",
	[0x13] = "r",
	[0x14] = "t",
	[0x15] = "y",
	[0x16] = "u",
	[0x17] = "i",
	[0x18] = "o",
	[0x19] = "p",
	[0x1A] = "[",
	[0x1B] = "]",
	[0x1C] = "\n",
	[0x1E] = "a",
	[0x1F] = "s",
	[0x20] = "d",
	[0x21] = "f",
	[0x22] = "g",
	[0x23] = "h",
	[0x24] = "j",
	[0x25] = "k",
	[0x26] = "l",
	[0x27] = ";",
	[0x28] = "'",
	[0x29] = "`",
	[0x2B] = "\\",
	[0x2C] = "z",
	[0x2D] = "x",
	[0x2E] = "c",
	[0x2F] = "v",
	[0x30] = "b",
	[0x31] = "n",
	[0x32] = "m",
	[0x33] = ",",
	[0x34] = ".",
	[0x35] = "/",
	[0x39] = " ",
}

local SC_TO_ASCII_UPPER = {
	[0x02] = "!",
	[0x03] = "@",
	[0x04] = "#",
	[0x05] = "$",
	[0x06] = "%",
	[0x07] = "^",
	[0x08] = "&",
	[0x09] = "*",
	[0x0A] = "(",
	[0x0B] = ")",
	[0x0C] = "_",
	[0x0D] = "+",
	[0x0E] = "\b",
	[0x0F] = "\t",
	[0x10] = "Q",
	[0x11] = "W",
	[0x12] = "E",
	[0x13] = "R",
	[0x14] = "T",
	[0x15] = "Y",
	[0x16] = "U",
	[0x17] = "I",
	[0x18] = "O",
	[0x19] = "P",
	[0x1A] = "{",
	[0x1B] = "}",
	[0x1C] = "\n",
	[0x1E] = "A",
	[0x1F] = "S",
	[0x20] = "D",
	[0x21] = "F",
	[0x22] = "G",
	[0x23] = "H",
	[0x24] = "J",
	[0x25] = "K",
	[0x26] = "L",
	[0x27] = ":",
	[0x28] = '"',
	[0x29] = "~",
	[0x2B] = "|",
	[0x2C] = "Z",
	[0x2D] = "X",
	[0x2E] = "C",
	[0x2F] = "V",
	[0x30] = "B",
	[0x31] = "N",
	[0x32] = "M",
	[0x33] = "<",
	[0x34] = ">",
	[0x35] = "?",
	[0x39] = " ",
}

local function cloneSequence(entry)
	if type(entry) == "table" then
		return table.clone(entry)
	end
	return { entry }
end

function I8042Controller.new(config, bus)
	local self = setmetatable({}, I8042Controller)
	self.config = config
	self.bus = bus
	self._buffer = {}
	self._ascii = {}
	self._shift = false
	self._ctrl = false
	self._alt = false
	self._capsLock = false
	self._enabled = false
	self._scanningEnabled = true
	self._controllerCommandByte = bit32.bor(COMMAND_IRQ1_ENABLE, COMMAND_SYSTEM_FLAG)
	self._pendingControllerData = nil
	self._pendingI8042ControllerData = nil
	self._status = STATUS_SYSTEM
	self.stats = { keyPresses = 0, bufferOverruns = 0 }

	bus:registerPort(config.PORT.KBD_DATA, function()
		return self:_readData()
	end, function(v)
		self:_writeData(v)
	end, "KBD Data")
	bus:registerPort(config.PORT.KBD_STATUS, function()
		return self:_readStatus()
	end, function(v)
		self:_writeCtrl(v)
	end, "KBD Status/Ctrl")
	return self
end

function I8042Controller:_raiseIRQ()
	if bit32.band(self._controllerCommandByte, COMMAND_IRQ1_ENABLE) ~= 0 then
		self.bus:raiseIRQ(self.config.IRQ.KEYBOARD, { source = "keyboard", status = self._status })
	end
end

function I8042Controller:_pushOutputByte(value)
	if #self._buffer >= 64 then
		self.stats.bufferOverruns = self.stats.bufferOverruns + 1
		return
	end
	self._buffer[#self._buffer + 1] = bit32.band(tonumber(value) or 0, 0xFF)
	self._status = bit32.bor(self._status, STATUS_OUTPUT_FULL)
	self:_raiseIRQ()
end

function I8042Controller:_clearOutputStatus()
	if #self._buffer == 0 then
		self._status = bit32.band(self._status, bit32.bnot(STATUS_OUTPUT_FULL))
	end
end

function I8042Controller:_translateASCII(scanCode)
	local lower = SC_TO_ASCII_LOWER[scanCode]
	local upper = SC_TO_ASCII_UPPER[scanCode]
	local ascii
	if lower and upper then
		local isLetter = lower:match("^[a-z]$") ~= nil
		if isLetter then
			local useUpper = (self._shift and not self._capsLock) or (self._capsLock and not self._shift)
			ascii = useUpper and upper or lower
		else
			ascii = self._shift and upper or lower
		end
	else
		ascii = lower or upper
	end

	if self._ctrl and ascii and #ascii == 1 then
		local upperAscii = string.upper(ascii)
		local byte = string.byte(upperAscii)
		local code = byte - 64
		if code > 0 and code < 32 then
			ascii = string.char(code)
		end
	end

	if ascii and #self._ascii < 128 then
		self._ascii[#self._ascii + 1] = ascii
	end
end

function I8042Controller:_queueScanSequence(sequence, isBreak)
	local codes = cloneSequence(sequence)
	if isBreak then
		codes[#codes] = bit32.bor(codes[#codes], 0x80)
	end
	for _, code in ipairs(codes) do
		self:_pushOutputByte(code)
	end
end

function I8042Controller:_setModifierState(kc, isDown)
	if kc == Enum.KeyCode.LeftShift or kc == Enum.KeyCode.RightShift then
		self._shift = isDown
	elseif kc == Enum.KeyCode.LeftControl or kc == Enum.KeyCode.RightControl then
		self._ctrl = isDown
	elseif kc == Enum.KeyCode.LeftAlt or kc == Enum.KeyCode.RightAlt then
		self._alt = isDown
	elseif kc == Enum.KeyCode.CapsLock and isDown then
		self._capsLock = not self._capsLock
	end
end

function I8042Controller:bindRobloxInput(UIS)
	self:unbind()
	self._enabled = true
	self._uisDown = UIS.InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed then
			return
		end
		self:_onKeyDown(input)
	end)
	self._uisUp = UIS.InputEnded:Connect(function(input)
		self:_onKeyUp(input)
	end)
end

function I8042Controller:unbind()
	if self._uisDown then
		self._uisDown:Disconnect()
		self._uisDown = nil
	end
	if self._uisUp then
		self._uisUp:Disconnect()
		self._uisUp = nil
	end
	self._enabled = false
end

function I8042Controller:_onKeyDown(input)
	if input.UserInputType ~= Enum.UserInputType.Keyboard or not self._scanningEnabled then
		return
	end
	local kc = input.KeyCode
	self:_setModifierState(kc, true)

	local sequence = SCAN_MAKE[kc]
	if not sequence then
		return
	end

	self.stats.keyPresses = self.stats.keyPresses + 1
	self:_queueScanSequence(sequence, false)

	if type(sequence) ~= "table" then
		self:_translateASCII(sequence)
	end
end

function I8042Controller:_onKeyUp(input)
	if input.UserInputType ~= Enum.UserInputType.Keyboard or not self._scanningEnabled then
		return
	end
	local kc = input.KeyCode
	self:_setModifierState(kc, false)
	local sequence = SCAN_MAKE[kc]
	if sequence then
		self:_queueScanSequence(sequence, true)
	end
end

function I8042Controller:_readData()
	local value = table.remove(self._buffer, 1) or 0
	self:_clearOutputStatus()
	return value
end

function I8042Controller:_readStatus()
	return self._status
end

function I8042Controller:_writeI8042ControllerCommand(value)
	local v = bit32.band(tonumber(value) or 0, 0xFF)
	if self._pendingI8042ControllerData == "led" then
		self._pendingI8042ControllerData = nil
		self:_pushOutputByte(KBD_ACK)
		return
	end

	if v == 0xED then
		self._pendingI8042ControllerData = "led"
		self:_pushOutputByte(KBD_ACK)
	elseif v == 0xF2 then
		self:_pushOutputByte(KBD_ACK)
		self:_pushOutputByte(0xAB)
		self:_pushOutputByte(0x83)
	elseif v == 0xF4 then
		self._scanningEnabled = true
		self:_pushOutputByte(KBD_ACK)
	elseif v == 0xF5 then
		self._scanningEnabled = false
		self:_pushOutputByte(KBD_ACK)
	elseif v == 0xFF then
		self._buffer = {}
		self._ascii = {}
		self._scanningEnabled = true
		self:_pushOutputByte(KBD_ACK)
		self:_pushOutputByte(KBD_SELF_TEST_PASSED)
	else
		self:_pushOutputByte(KBD_ACK)
	end
end

function I8042Controller:_writeData(value)
	local v = bit32.band(tonumber(value) or 0, 0xFF)
	if self._pendingControllerData == "command-byte" then
		self._controllerCommandByte = v
		self._pendingControllerData = nil
		self._status = bit32.band(self._status, bit32.bnot(STATUS_INPUT_FULL))
		return
	end
	self:_writeI8042ControllerCommand(v)
end

function I8042Controller:_writeCtrl(value)
	local v = bit32.band(tonumber(value) or 0, 0xFF)
	self._status = bit32.bor(self._status, STATUS_COMMAND)
	if v == 0x20 then
		self:_pushOutputByte(self._controllerCommandByte)
	elseif v == 0x60 then
		self._pendingControllerData = "command-byte"
		self._status = bit32.bor(self._status, STATUS_INPUT_FULL)
	elseif v == 0xAA then
		self._status = bit32.bor(self._status, STATUS_SYSTEM)
		self:_pushOutputByte(0x55)
	elseif v == 0xAB then
		self:_pushOutputByte(0x00)
	elseif v == 0xAD then
		self._scanningEnabled = false
		self._controllerCommandByte = bit32.bor(self._controllerCommandByte, COMMAND_DISABLE_KEYBOARD)
	elseif v == 0xAE then
		self._scanningEnabled = true
		self._controllerCommandByte = bit32.band(self._controllerCommandByte, bit32.bnot(COMMAND_DISABLE_KEYBOARD))
	elseif v == 0xFE then
		self:_pushOutputByte(0x00)
	end
	self._status = bit32.band(self._status, bit32.bnot(STATUS_COMMAND))
end

function I8042Controller:readChar()
	return table.remove(self._ascii, 1)
end

function I8042Controller:peekChar()
	return self._ascii[1]
end

function I8042Controller:pollLine(currentLine, echo, gpu)
	local ch = self:readChar()
	if not ch then
		return nil
	end

	if ch == "\n" or ch == "\r" then
		local line = table.concat(currentLine)
		for i = #currentLine, 1, -1 do
			currentLine[i] = nil
		end
		if echo and gpu then
			gpu:print("\n")
		end
		return line
	elseif ch == "\b" then
		if #currentLine > 0 then
			table.remove(currentLine)
			if echo and gpu then
				gpu:print("\b")
			end
		end
	else
		table.insert(currentLine, ch)
		if echo and gpu then
			gpu:print(ch)
		end
	end
	return nil
end

function I8042Controller:getStats()
	return self.stats
end

return I8042Controller
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="28">
            <Properties>
              <string name="Name">PhysicalMemory</string>
              <string name="Source"><![CDATA[-- PhysicalMemory module

local PhysicalMemory = {}
PhysicalMemory.__index = PhysicalMemory

function PhysicalMemory.new(config)
	local self = setmetatable({}, PhysicalMemory)
	self.config = config
	self.size = config.RAM_SIZE or config.LOW_RAM_SIZE or 0
	self._mem = {} -- sparse: addr â†’ byte value
	self._dirty = {} -- page_index â†’ true/false

	-- ECC simulation counters
	self.stats = { reads = 0, writes = 0, eccCorrections = 0 }
	return self
end

function PhysicalMemory:memRead(offset)
	self.stats.reads = self.stats.reads + 1
	return self._mem[offset] or 0
end

function PhysicalMemory:memWrite(offset, value)
	self.stats.writes = self.stats.writes + 1
	self._mem[offset] = value % 256
	-- mark page dirty
	local page = math.floor(offset / self.config.PAGE_SIZE)
	self._dirty[page] = true
end

function PhysicalMemory:readRegion(offset, length)
	local out = {}
	for i = 0, length - 1 do
		table.insert(out, self._mem[offset + i] or 0)
	end
	return out
end

function PhysicalMemory:writeRegion(offset, bytes)
	for i, b in ipairs(bytes) do
		self._mem[offset + i - 1] = b % 256
	end
	local page = math.floor(offset / self.config.PAGE_SIZE)
	self._dirty[page] = true
end

function PhysicalMemory:clear(offset, length)
	for i = 0, length - 1 do
		self._mem[offset + i] = 0
	end
end

function PhysicalMemory:getUsedBytes()
	local n = 0
	for _ in pairs(self._mem) do
		n = n + 1
	end
	return n
end

function PhysicalMemory:getDirtyPageCount()
	local n = 0
	for _ in pairs(self._dirty) do
		n = n + 1
	end
	return n
end

function PhysicalMemory:clearDirty()
	self._dirty = {}
end
function PhysicalMemory:getStats()
	return self.stats
end

return PhysicalMemory
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="29">
            <Properties>
              <string name="Name">Pic8259</string>
              <string name="Source"><![CDATA[local Pic8259 = {}
Pic8259.__index = Pic8259

local function bit(mask, n)
	return bit32.band(mask, bit32.lshift(1, n)) ~= 0
end

local function clearBit(mask, n)
	return bit32.band(mask, bit32.bnot(bit32.lshift(1, n)))
end

local function setBit(mask, n)
	return bit32.bor(mask, bit32.lshift(1, n))
end

local function newChip(defaultBase)
	return {
		vectorBase = defaultBase,
		imr = 0x00,
		irr = 0x00,
		isr = 0x00,
		readRegister = "IRR",
		priorityAdd = 0,
		initStep = 0,
		icw4Needed = false,
		singleMode = false,
		icw3 = 0,
		autoEOI = false,
	}
end

local function priorityOrder(chip, slot)
	return (chip.priorityAdd + slot) % 8
end

local function highestPriorityBit(chip, mask)
	for slot = 0, 7 do
		local irq = priorityOrder(chip, slot)
		if bit(mask, irq) then
			return irq
		end
	end
	return nil
end

local function highestInService(chip)
	return highestPriorityBit(chip, chip.isr)
end

local function nextDeliverableIRQ(chip)
	local pending = bit32.band(chip.irr, bit32.bnot(chip.imr))
	if pending == 0 then
		return nil
	end
	local inService = highestInService(chip)
	if inService == nil then
		return highestPriorityBit(chip, pending)
	end
	for slot = 0, 7 do
		local irq = priorityOrder(chip, slot)
		if irq == inService then
			break
		end
		if bit(pending, irq) then
			return irq
		end
	end
	return nil
end

local function acknowledgeIRQ(chip, irq)
	chip.irr = clearBit(chip.irr, irq)
	if not chip.autoEOI then
		chip.isr = setBit(chip.isr, irq)
	end
end

local function nonspecificEOI(chip)
	local irq = highestInService(chip)
	if irq ~= nil then
		chip.isr = clearBit(chip.isr, irq)
	end
	return irq
end

function Pic8259.new(config)
	local self = setmetatable({}, Pic8259)
	self.config = config
	self.master = newChip(config.PIC_VECTOR_BASE_MASTER or 0x20)
	self.slave = newChip(config.PIC_VECTOR_BASE_SLAVE or 0x28)
	self.master.icw3 = 0x04
	self.slave.icw3 = 0x02

	self.stats = {
		raised = 0,
		delivered = 0,
		eoi = 0,
		spurious = 0,
	}
	return self
end

function Pic8259:attachBus(bus)
	self._bus = bus
	bus:registerPort(self.config.PORT.PIC_MASTER_CMD, function()
		return self:_readCommand(self.master)
	end, function(v)
		self:_writeCommand(self.master, v)
	end, "Pic8259 Master CMD")
	bus:registerPort(self.config.PORT.PIC_MASTER_DATA, function()
		return self.master.imr
	end, function(v)
		self:_writeData(self.master, v)
	end, "Pic8259 Master DATA")

	bus:registerPort(self.config.PORT.PIC_SLAVE_CMD, function()
		return self:_readCommand(self.slave)
	end, function(v)
		self:_writeCommand(self.slave, v)
	end, "Pic8259 Slave CMD")
	bus:registerPort(self.config.PORT.PIC_SLAVE_DATA, function()
		return self.slave.imr
	end, function(v)
		self:_writeData(self.slave, v)
	end, "Pic8259 Slave DATA")
end

function Pic8259:raiseIRQ(irqNum)
	irqNum = tonumber(irqNum) or -1
	if irqNum < 0 or irqNum > 15 then
		self.stats.spurious = self.stats.spurious + 1
		return false
	end
	self.stats.raised = self.stats.raised + 1
	if irqNum < 8 then
		self.master.irr = setBit(self.master.irr, irqNum)
	else
		self.slave.irr = setBit(self.slave.irr, irqNum - 8)
		self.master.irr = setBit(self.master.irr, 2)
	end
	return true
end

function Pic8259:hasPending()
	return self:_nextMasterIRQ() ~= nil
end

function Pic8259:_nextMasterIRQ()
	local pending = bit32.band(self.master.irr, bit32.bnot(self.master.imr))
	if pending == 0 then
		return nil
	end
	local inService = highestInService(self.master)
	for slot = 0, 7 do
		local irq = priorityOrder(self.master, slot)
		if inService ~= nil and irq == inService then
			break
		end
		if bit(pending, irq) then
			if irq ~= 2 or nextDeliverableIRQ(self.slave) ~= nil then
				return irq
			end
		end
	end
	return nil
end

function Pic8259:getNextVector()
	local masterIRQ = self:_nextMasterIRQ()
	if masterIRQ == nil then
		return nil
	end

	if masterIRQ == 2 then
		local slaveIRQ = nextDeliverableIRQ(self.slave)
		if slaveIRQ ~= nil then
			acknowledgeIRQ(self.master, 2)
			acknowledgeIRQ(self.slave, slaveIRQ)
			if self.slave.irr == 0 then
				self.master.irr = clearBit(self.master.irr, 2)
			end
			self.stats.delivered = self.stats.delivered + 1
			return (self.slave.vectorBase + slaveIRQ) % 0x100
		end
	end

	acknowledgeIRQ(self.master, masterIRQ)
	self.stats.delivered = self.stats.delivered + 1
	return (self.master.vectorBase + masterIRQ) % 0x100
end

function Pic8259:endOfInterrupt(vector)
	vector = tonumber(vector) or -1
	if vector >= self.slave.vectorBase and vector < self.slave.vectorBase + 8 then
		local irq = vector - self.slave.vectorBase
		self.slave.isr = clearBit(self.slave.isr, irq)
		self.master.isr = clearBit(self.master.isr, 2)
		self.stats.eoi = self.stats.eoi + 1
		return true
	end
	if vector >= self.master.vectorBase and vector < self.master.vectorBase + 8 then
		local irq = vector - self.master.vectorBase
		self.master.isr = clearBit(self.master.isr, irq)
		self.stats.eoi = self.stats.eoi + 1
		return true
	end
	return false
end

function Pic8259:_readCommand(chip)
	return chip.readRegister == "ISR" and chip.isr or chip.irr
end

function Pic8259:_writeCommand(chip, value)
	local v = bit32.band(tonumber(value) or 0, 0xFF)
	if bit32.band(v, 0x10) ~= 0 then
		chip.initStep = 1
		chip.icw4Needed = bit32.band(v, 0x01) ~= 0
		chip.singleMode = bit32.band(v, 0x02) ~= 0
		chip.irr = 0
		chip.isr = 0
		return
	end

	if bit32.band(v, 0x08) ~= 0 then
		if bit32.band(v, 0x02) ~= 0 then
			chip.readRegister = bit32.band(v, 0x01) ~= 0 and "ISR" or "IRR"
		end
		return
	end

	local command = bit32.band(v, 0xE0)
	if command == 0x20 then
		if nonspecificEOI(chip) ~= nil then
			self.stats.eoi = self.stats.eoi + 1
		end
		return
	end
	if command == 0x60 then
		chip.isr = clearBit(chip.isr, bit32.band(v, 0x07))
		self.stats.eoi = self.stats.eoi + 1
		return
	end
	if command == 0xA0 then
		chip.isr = clearBit(chip.isr, bit32.band(v, 0x07))
		chip.priorityAdd = (bit32.band(v, 0x07) + 1) % 8
		self.stats.eoi = self.stats.eoi + 1
	end
end

function Pic8259:_writeData(chip, value)
	local v = bit32.band(tonumber(value) or 0, 0xFF)
	if chip.initStep == 1 then
		chip.vectorBase = bit32.band(v, 0xF8)
		chip.initStep = 2
		return
	end
	if chip.initStep == 2 then
		chip.icw3 = v
		chip.initStep = chip.icw4Needed and 3 or 0
		return
	end
	if chip.initStep == 3 then
		chip.autoEOI = bit32.band(v, 0x02) ~= 0
		chip.initStep = 0
		return
	end
	chip.imr = v
end

function Pic8259:getStats()
	return self.stats
end

return Pic8259
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="30">
            <Properties>
              <string name="Name">Pit8254</string>
              <string name="Source"><![CDATA[local Pit8254 = {}
Pit8254.__index = Pit8254

local function newChannel(defaultReload)
	return {
		reloadValue = defaultReload or 0,
		accessMode = 3,
		mode = 3,
		bcd = false,
		writeLatch = nil,
		readFlipFlop = 0,
		writeFlipFlop = 0,
		latchValue = nil,
		accumulatedTicks = 0,
		running = true,
	}
end

local function effectiveReload(channel)
	local value = channel.reloadValue
	if value == 0 then
		return 0x10000
	end
	return value
end

function Pit8254.new(config)
	local self = setmetatable({}, Pit8254)
	self.config = config

	local timerCfg = config.TIMER or {}
	self._baseHz = timerCfg.BASE_HZ or 1193182
	self._channels = {
		[0] = newChannel(timerCfg.DEFAULT_DIVISOR or 0),
		[1] = newChannel(0),
		[2] = newChannel(0),
	}
	self._subTicks = 0
	self._enabled = true
	self._irqEnabled = true

	self.stats = {
		ticks = 0,
		irqs = 0,
	}
	return self
end

function Pit8254:attachBus(bus)
	self._bus = bus
	bus:registerPort(self.config.PORT.PIT_CHAN0, function()
		return self:_readChannel(0)
	end, function(v)
		self:_writeChannel(0, v)
	end, "PIT CH0")
	bus:registerPort(self.config.PORT.PIT_CHAN0 + 1, function()
		return self:_readChannel(1)
	end, function(v)
		self:_writeChannel(1, v)
	end, "PIT CH1")
	bus:registerPort(self.config.PORT.PIT_CHAN0 + 2, function()
		return self:_readChannel(2)
	end, function(v)
		self:_writeChannel(2, v)
	end, "PIT CH2")
	bus:registerPort(self.config.PORT.PIT_CMD, function()
		return 0
	end, function(v)
		self:_writeCommand(v)
	end, "PIT CMD")
end

function Pit8254:_currentCount(channel)
	local reload = effectiveReload(channel)
	if reload <= 0 then
		return 0
	end
	local phase = math.floor(channel.accumulatedTicks) % reload
	local count = reload - phase
	if count == reload then
		count = 0
	end
	return count % 0x10000
end

function Pit8254:_latchCount(channel)
	channel.latchValue = self:_currentCount(channel)
	channel.readFlipFlop = 0
end

function Pit8254:_readLatchedByte(channel, value)
	if channel.accessMode == 1 then
		return value % 0x100
	end
	if channel.accessMode == 2 then
		return math.floor(value / 0x100) % 0x100
	end
	local byteValue
	if channel.readFlipFlop == 0 then
		byteValue = value % 0x100
	else
		byteValue = math.floor(value / 0x100) % 0x100
	end
	channel.readFlipFlop = 1 - channel.readFlipFlop
	if channel.readFlipFlop == 0 then
		channel.latchValue = nil
	end
	return byteValue
end

function Pit8254:_readChannel(index)
	local channel = self._channels[index]
	if not channel then
		return 0
	end
	local value = channel.latchValue
	if value == nil then
		value = self:_currentCount(channel)
	end
	return self:_readLatchedByte(channel, value)
end

function Pit8254:_commitReload(channel, value)
	channel.reloadValue = value % 0x10000
	channel.accumulatedTicks = 0
	channel.running = true
	channel.latchValue = nil
	channel.readFlipFlop = 0
end

function Pit8254:_writeChannel(index, value)
	local channel = self._channels[index]
	if not channel then
		return
	end
	local byteValue = bit32.band(tonumber(value) or 0, 0xFF)
	if channel.accessMode == 1 then
		self:_commitReload(channel, byteValue)
		return
	end
	if channel.accessMode == 2 then
		self:_commitReload(channel, bit32.lshift(byteValue, 8))
		return
	end
	if channel.writeFlipFlop == 0 then
		channel.writeLatch = byteValue
		channel.writeFlipFlop = 1
	else
		self:_commitReload(channel, channel.writeLatch + bit32.lshift(byteValue, 8))
		channel.writeLatch = nil
		channel.writeFlipFlop = 0
	end
end

function Pit8254:_writeCommand(value)
	local v = bit32.band(tonumber(value) or 0, 0xFF)
	local select = bit32.rshift(v, 6)
	if select == 3 then
		return
	end
	local channel = self._channels[select]
	if not channel then
		return
	end
	local accessMode = bit32.band(bit32.rshift(v, 4), 0x03)
	local mode = bit32.band(bit32.rshift(v, 1), 0x07)
	if mode == 6 then
		mode = 2
	elseif mode == 7 then
		mode = 3
	end
	if accessMode == 0 then
		self:_latchCount(channel)
		return
	end
	channel.accessMode = accessMode
	channel.mode = mode
	channel.bcd = bit32.band(v, 0x01) ~= 0
	channel.writeLatch = nil
	channel.writeFlipFlop = 0
	channel.readFlipFlop = 0
	channel.latchValue = nil
end

function Pit8254:_fireIRQ(count)
	if not self._bus or not self._irqEnabled or count <= 0 then
		return
	end
	for _ = 1, count do
		self._bus:raiseIRQ(self.config.IRQ.TIMER, { source = "pit", channel = 0 })
		self.stats.irqs = self.stats.irqs + 1
	end
end

function Pit8254:_tickChannel0(elapsedTicks)
	local channel = self._channels[0]
	if not channel or not channel.running then
		return
	end

	local reload = effectiveReload(channel)
	if reload <= 0 then
		return
	end

	local previous = channel.accumulatedTicks
	channel.accumulatedTicks = channel.accumulatedTicks + elapsedTicks

	if channel.mode == 0 then
		if previous < reload and channel.accumulatedTicks >= reload then
			channel.running = false
			self:_fireIRQ(1)
		end
		return
	end

	if channel.mode ~= 2 and channel.mode ~= 3 then
		return
	end

	local completed = math.floor(channel.accumulatedTicks / reload) - math.floor(previous / reload)
	if completed > 0 then
		self:_fireIRQ(completed)
	end
end

function Pit8254:tick(dt)
	self.stats.ticks = self.stats.ticks + 1
	if not self._enabled then
		return
	end
	dt = tonumber(dt) or 0
	if dt <= 0 then
		return
	end

	self._subTicks = self._subTicks + dt * self._baseHz
	local elapsedTicks = math.floor(self._subTicks)
	if elapsedTicks <= 0 then
		return
	end
	self._subTicks = self._subTicks - elapsedTicks
	self:_tickChannel0(elapsedTicks)
end

function Pit8254:memRead(offset)
	offset = tonumber(offset) or -1
	if offset == 0x00 then
		return self:_readChannel(0)
	elseif offset == 0x01 then
		return self:_readChannel(1)
	elseif offset == 0x02 then
		return self:_readChannel(2)
	elseif offset == 0x03 then
		return 0
	end
	return 0
end

function Pit8254:memWrite(offset, value)
	offset = tonumber(offset) or -1
	if offset == 0x00 then
		self:_writeChannel(0, value)
	elseif offset == 0x01 then
		self:_writeChannel(1, value)
	elseif offset == 0x02 then
		self:_writeChannel(2, value)
	elseif offset == 0x03 then
		self:_writeCommand(value)
	end
end

function Pit8254:getStats()
	return self.stats
end

return Pit8254
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="31">
            <Properties>
              <string name="Name">SystemBus</string>
              <string name="Source"><![CDATA[-- SystemBus module

local SystemBus = {}
SystemBus.__index = SystemBus

local function defaultTickDt(config)
	local hz = math.max(config.CPU_CLOCK_HZ or 1, config.DISPLAY_REFRESH_HZ or 60)
	return 1 / math.max(1, hz)
end

function SystemBus.new(config)
	local self = setmetatable({}, SystemBus)
	self.config = config
	self._devices = {} -- name -> device object
	self._memmap = {} -- {base, size, device, tag, readOnly}
	self._portmap = {} -- port_number -> handler function
	self._irqLines = {} -- registered IRQ callbacks: irq_num -> {handler, device, count, active}
	self._dmaQueue = {} -- pending DMA transfers
	self._logs = {}
	self._fault = nil
	self._defaultDt = defaultTickDt(config)

	-- Statistics
	self.stats = {
		memReads = 0,
		memWrites = 0,
		portReads = 0,
		portWrites = 0,
		irqFired = 0,
		irqDelivered = 0,
		dmaBytes = 0,
		faults = 0,
	}

	local Pic8259Module = require(script.Parent.Pic8259)
	local Pit8254Module = require(script.Parent.Pit8254)
	self.pic = Pic8259Module.new(config)
	self.timer = Pit8254Module.new(config)
	self._devices.pic = self.pic
	self._devices.timer = self.timer
	self.pic:attachBus(self)
	self.timer:attachBus(self)

	return self
end

-- Device Registration

function SystemBus:registerDevice(name, device)
	assert(not self._devices[name], "SystemBus: device '" .. name .. "' already registered")
	self._devices[name] = device
	if name == "cpu" then
		self._cpu = device
	end
	if device and type(device.attachBus) == "function" then
		pcall(function()
			device:attachBus(self)
		end)
	end
	self:_log("BUS", "Device registered: " .. name)
end

function SystemBus:getDevice(name)
	return self._devices[name]
end

-- Memory Map

-- device must implement :memRead(offset) and :memWrite(offset, value)
function SystemBus:mapMemory(base, size, device, tag, opts)
	opts = opts or {}
	local readOnly = opts.readOnly == true or (type(tag) == "string" and tag:find("ROM") ~= nil)
	table.insert(self._memmap, {
		base = base,
		size = size,
		device = device,
		tag = tag or "?",
		readOnly = readOnly,
	})
	table.sort(self._memmap, function(a, b)
		return a.base < b.base
	end)
	self:_log("BUS", string.format("Mapped [%08X-%08X] -> %s", base, base + size - 1, tag or "?"))
end

local function findMapping(self, addr)
	for _, m in ipairs(self._memmap) do
		if addr >= m.base and addr < m.base + m.size then
			return m
		end
	end
	return nil
end

function SystemBus:_setFault(kind, addr, op, detail)
	self.stats.faults = self.stats.faults + 1
	self._fault = {
		kind = kind,
		addr = addr,
		op = op,
		detail = detail,
		time = os.clock(),
	}
	self:_log(
		"BUS",
		string.format("FAULT %s op=%s addr=%08X (%s)", tostring(kind), tostring(op), addr or 0, tostring(detail))
	)
end

function SystemBus:peekFault()
	return self._fault
end

function SystemBus:consumeFault()
	local f = self._fault
	self._fault = nil
	return f
end

function SystemBus:memRead(addr)
	self.stats.memReads = self.stats.memReads + 1
	local m = findMapping(self, addr)
	if not m then
		self:_setFault("unmapped-read", addr, "read8", "Address not mapped")
		return 0xFF
	end
	local ok, value = pcall(function()
		return m.device:memRead(addr - m.base)
	end)
	if not ok then
		self:_setFault("device-read-fault", addr, "read8", value)
		return 0xFF
	end
	if value == nil then
		self:_setFault("device-read-nil", addr, "read8", m.tag)
		return 0xFF
	end
	return (tonumber(value) or 0) % 256
end

function SystemBus:memWrite(addr, value)
	self.stats.memWrites = self.stats.memWrites + 1
	local m = findMapping(self, addr)
	if not m then
		self:_setFault("unmapped-write", addr, "write8", "Address not mapped")
		return false
	end
	if m.readOnly then
		self:_setFault("readonly-write", addr, "write8", m.tag)
		return false
	end
	local ok, err = pcall(function()
		m.device:memWrite(addr - m.base, (tonumber(value) or 0) % 256)
	end)
	if not ok then
		self:_setFault("device-write-fault", addr, "write8", err)
		return false
	end
	return true
end

-- 32-bit word helpers
function SystemBus:memRead32(addr)
	local b0 = self:memRead(addr)
	local b1 = self:memRead(addr + 1)
	local b2 = self:memRead(addr + 2)
	local b3 = self:memRead(addr + 3)
	return b0 + b1 * 256 + b2 * 65536 + b3 * 16777216
end

function SystemBus:memWrite32(addr, value)
	local v = tonumber(value) or 0
	local ok0 = self:memWrite(addr, v % 256)
	local ok1 = self:memWrite(addr + 1, math.floor(v / 256) % 256)
	local ok2 = self:memWrite(addr + 2, math.floor(v / 65536) % 256)
	local ok3 = self:memWrite(addr + 3, math.floor(v / 16777216) % 256)
	return ok0 and ok1 and ok2 and ok3
end

-- Port I/O

function SystemBus:registerPort(port, readFn, writeFn, label, read16Fn, write16Fn, read32Fn, write32Fn)
	self._portmap[port] = {
		read = readFn,
		write = writeFn,
		read16 = read16Fn,
		write16 = write16Fn,
		read32 = read32Fn,
		write32 = write32Fn,
		label = label or string.format("0x%04X", port),
	}
end

function SystemBus:portRead(port)
	self.stats.portReads = self.stats.portReads + 1
	local h = self._portmap[port]
	if h and h.read then
		local ok, value = pcall(h.read)
		if ok then
			return (tonumber(value) or 0) % 256
		end
	end
	return 0xFF
end

function SystemBus:portWrite(port, value)
	self.stats.portWrites = self.stats.portWrites + 1
	local h = self._portmap[port]
	if h and h.write then
		local ok, err = pcall(h.write, (tonumber(value) or 0) % 256)
		if not ok then
			self:_setFault("port-write-fault", port, "out", err)
		end
	end
end

function SystemBus:portRead16(port)
	self.stats.portReads = self.stats.portReads + 1
	local h = self._portmap[port]
	if h and h.read16 then
		local ok, value = pcall(h.read16)
		if ok then
			return (tonumber(value) or 0) % 0x10000
		end
	end
	local lo = self:portRead(port)
	local hi = self:portRead(port + 1)
	return lo + hi * 0x100
end

function SystemBus:portWrite16(port, value)
	self.stats.portWrites = self.stats.portWrites + 1
	local h = self._portmap[port]
	local masked = (tonumber(value) or 0) % 0x10000
	if h and h.write16 then
		local ok, err = pcall(h.write16, masked)
		if not ok then
			self:_setFault("port-write-fault", port, "out16", err)
		end
		return
	end
	self:portWrite(port, masked % 0x100)
	self:portWrite(port + 1, math.floor(masked / 0x100) % 0x100)
end

function SystemBus:portRead32(port)
	self.stats.portReads = self.stats.portReads + 1
	local h = self._portmap[port]
	if h and h.read32 then
		local ok, value = pcall(h.read32)
		if ok then
			return (tonumber(value) or 0) % 0x100000000
		end
	end
	local lo = self:portRead16(port)
	local hi = self:portRead16(port + 2)
	return lo + hi * 0x10000
end

function SystemBus:portWrite32(port, value)
	self.stats.portWrites = self.stats.portWrites + 1
	local h = self._portmap[port]
	local masked = (tonumber(value) or 0) % 0x100000000
	if h and h.write32 then
		local ok, err = pcall(h.write32, masked)
		if not ok then
			self:_setFault("port-write-fault", port, "out32", err)
		end
		return
	end
	self:portWrite16(port, masked % 0x10000)
	self:portWrite16(port + 2, math.floor(masked / 0x10000) % 0x10000)
end

-- IRQ (Interrupt Request Lines)

function SystemBus:registerIRQ(irqNum, device, handler)
	if not self._irqLines[irqNum] then
		self._irqLines[irqNum] = {}
	end
	table.insert(self._irqLines[irqNum], { device = device, handler = handler, count = 0, active = false })
	self:_log("BUS", string.format("IRQ%d registered for device: %s", irqNum, tostring(device)))
end

-- Fire an interrupt: queue into PIC and notify registered IRQ callbacks.
function SystemBus:raiseIRQ(irqNum, data)
	self.stats.irqFired = self.stats.irqFired + 1
	if self.pic then
		self.pic:raiseIRQ(irqNum)
	end

	local handlers = self._irqLines[irqNum]
	if not handlers then
		return
	end
	for _, h in ipairs(handlers) do
		h.count = h.count + 1
		h.active = true
		local ok, err = pcall(h.handler, irqNum, data)
		if not ok then
			self:_log("BUS", "IRQ handler error IRQ" .. irqNum .. ": " .. tostring(err))
		end
		h.active = false
	end
end

function SystemBus:hasPendingInterrupt()
	return self.pic and self.pic:hasPending() or false
end

function SystemBus:getPendingInterruptVector()
	if not self.pic then
		return nil
	end
	local vec = self.pic:getNextVector()
	if vec ~= nil then
		self.stats.irqDelivered = self.stats.irqDelivered + 1
	end
	return vec
end

function SystemBus:endOfInterrupt(vector)
	if self.pic then
		return self.pic:endOfInterrupt(vector)
	end
	return false
end

function SystemBus:getIRQStats()
	local out = {}
	for irq, handlers in pairs(self._irqLines) do
		for _, h in ipairs(handlers) do
			table.insert(out, { irq = irq, device = tostring(h.device), count = h.count, active = h.active })
		end
	end
	return out
end

-- DMA (Direct Memory Access)

-- Enqueue a DMA transfer. src/dst are physical addresses; callback fires on completion.
function SystemBus:dmaTransfer(src, dst, length, callback)
	table.insert(self._dmaQueue, { src = src, dst = dst, length = length, cb = callback, done = false })
end

-- Process all pending DMA transfers.
function SystemBus:processDMA(dt)
	for _, xfer in ipairs(self._dmaQueue) do
		if not xfer.done then
			for off = 0, xfer.length - 1 do
				local byte = self:memRead(xfer.src + off)
				self:memWrite(xfer.dst + off, byte)
			end
			self.stats.dmaBytes = self.stats.dmaBytes + xfer.length
			xfer.done = true
			if xfer.cb then
				pcall(xfer.cb)
			end
		end
	end

	local live = {}
	for _, x in ipairs(self._dmaQueue) do
		if not x.done then
			table.insert(live, x)
		end
	end
	self._dmaQueue = live

	self:tick(dt)
end

function SystemBus:tick(dt)
	dt = tonumber(dt) or self._defaultDt
	if self.timer and type(self.timer.tick) == "function" then
		self.timer:tick(dt)
	end
	-- Let devices progress asynchronous operations.
	for name, device in pairs(self._devices) do
		if name ~= "timer" and name ~= "pic" and name ~= "cpu" and type(device.tick) == "function" then
			device:tick(dt)
		end
	end
end

-- Internal logging

function SystemBus:_log(tag, msg)
	local entry = string.format("[%s] %s", tag, msg)
	table.insert(self._logs, entry)
	if #self._logs > 500 then
		table.remove(self._logs, 1)
	end
end

function SystemBus:getLog(n)
	n = n or #self._logs
	local start = math.max(1, #self._logs - n + 1)
	local out = {}
	for i = start, #self._logs do
		table.insert(out, self._logs[i])
	end
	return out
end

function SystemBus:getStats()
	return self.stats
end

return SystemBus
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="32">
            <Properties>
              <string name="Name">Uart8250</string>
              <string name="Source"><![CDATA[local Uart8250 = {}
Uart8250.__index = Uart8250

local IER_RX_AVAILABLE = 0x01
local IER_TX_EMPTY = 0x02

local IIR_NO_INTERRUPT = 0x01
local IIR_TX_EMPTY = 0x02
local IIR_RX_AVAILABLE = 0x04

local LCR_DLAB = 0x80
local MCR_LOOP = 0x10

local LSR_DATA_READY = 0x01
local LSR_THR_EMPTY = 0x20
local LSR_TX_EMPTY = 0x40

function Uart8250.new(config)
	local self = setmetatable({}, Uart8250)
	self.config = config
	self._bus = nil
	self._basePort = config.PORT.COM1_BASE
	self._irqLine = (config.IRQ and config.IRQ.COM1) or 4

	self._divisor = 12
	self._ier = 0x00
	self._iir = IIR_NO_INTERRUPT
	self._fcr = 0x00
	self._lcr = 0x03
	self._mcr = 0x00
	self._lsr = bit32.bor(LSR_THR_EMPTY, LSR_TX_EMPTY)
	self._msr = 0xB0
	self._scr = 0x00
	self._rxFifo = {}
	self._txLog = {}
	self._irqPending = false

	self.stats = {
		rxBytes = 0,
		txBytes = 0,
		irqs = 0,
	}

	return self
end

function Uart8250:attachBus(bus)
	self._bus = bus
	local base = self._basePort
	bus:registerPort(base + 0, function()
		return self:_readData()
	end, function(v)
		self:_writeData(v)
	end, "COM1 Data")
	bus:registerPort(base + 1, function()
		return self:_readIER()
	end, function(v)
		self:_writeIER(v)
	end, "COM1 IER")
	bus:registerPort(base + 2, function()
		return self:_readIIR()
	end, function(v)
		self:_writeFCR(v)
	end, "COM1 IIR/FCR")
	bus:registerPort(base + 3, function()
		return self._lcr
	end, function(v)
		self._lcr = bit32.band(tonumber(v) or 0, 0xFF)
	end, "COM1 LCR")
	bus:registerPort(base + 4, function()
		return self._mcr
	end, function(v)
		self._mcr = bit32.band(tonumber(v) or 0, 0xFF)
	end, "COM1 MCR")
	bus:registerPort(base + 5, function()
		return self:_readLSR()
	end, nil, "COM1 LSR")
	bus:registerPort(base + 6, function()
		return self._msr
	end, nil, "COM1 MSR")
	bus:registerPort(base + 7, function()
		return self._scr
	end, function(v)
		self._scr = bit32.band(tonumber(v) or 0, 0xFF)
	end, "COM1 SCR")
end

function Uart8250:_dlabEnabled()
	return bit32.band(self._lcr, LCR_DLAB) ~= 0
end

function Uart8250:_updateIRQ()
	local reason = nil
	if #self._rxFifo > 0 and bit32.band(self._ier, IER_RX_AVAILABLE) ~= 0 then
		reason = IIR_RX_AVAILABLE
	elseif bit32.band(self._ier, IER_TX_EMPTY) ~= 0 then
		reason = IIR_TX_EMPTY
	end

	if reason then
		self._iir = reason
		if not self._irqPending and self._bus then
			self._irqPending = true
			self.stats.irqs = self.stats.irqs + 1
			self._bus:raiseIRQ(self._irqLine, { source = "serial", iir = reason })
		end
	else
		self._iir = IIR_NO_INTERRUPT
		self._irqPending = false
	end
end

function Uart8250:_readData()
	if self:_dlabEnabled() then
		return self._divisor % 0x100
	end
	local value = table.remove(self._rxFifo, 1) or 0
	if #self._rxFifo == 0 then
		self._lsr = bit32.band(self._lsr, bit32.bnot(LSR_DATA_READY))
	end
	self._irqPending = false
	self:_updateIRQ()
	return value
end

function Uart8250:_writeData(v)
	local value = bit32.band(tonumber(v) or 0, 0xFF)
	if self:_dlabEnabled() then
		self._divisor = bit32.bor(bit32.band(self._divisor, 0xFF00), value)
		return
	end
	if bit32.band(self._mcr, MCR_LOOP) ~= 0 then
		self:pushInputByte(value)
		return
	end
	self.stats.txBytes = self.stats.txBytes + 1
	self._txLog[#self._txLog + 1] = value
	if #self._txLog > 4096 then
		table.remove(self._txLog, 1)
	end
	self._lsr = bit32.bor(self._lsr, LSR_THR_EMPTY, LSR_TX_EMPTY)
	self._irqPending = false
	self:_updateIRQ()
end

function Uart8250:_readIER()
	if self:_dlabEnabled() then
		return bit32.rshift(self._divisor, 8) % 0x100
	end
	return self._ier
end

function Uart8250:_writeIER(v)
	local value = bit32.band(tonumber(v) or 0, 0xFF)
	if self:_dlabEnabled() then
		self._divisor = bit32.bor(bit32.band(self._divisor, 0x00FF), bit32.lshift(value, 8))
		return
	end
	self._ier = bit32.band(value, 0x0F)
	self._irqPending = false
	self:_updateIRQ()
end

function Uart8250:_readIIR()
	local value = self._iir
	if bit32.band(value, IIR_NO_INTERRUPT) == 0 and value == IIR_TX_EMPTY then
		self._irqPending = false
		self:_updateIRQ()
	end
	return value
end

function Uart8250:_writeFCR(v)
	local value = bit32.band(tonumber(v) or 0, 0xFF)
	self._fcr = value
	if bit32.band(value, 0x02) ~= 0 or bit32.band(value, 0x04) ~= 0 then
		self._rxFifo = {}
		self._lsr = bit32.band(self._lsr, bit32.bnot(LSR_DATA_READY))
	end
end

function Uart8250:_readLSR()
	return self._lsr
end

function Uart8250:pushInputByte(value)
	local byteValue = bit32.band(tonumber(value) or 0, 0xFF)
	self._rxFifo[#self._rxFifo + 1] = byteValue
	self._lsr = bit32.bor(self._lsr, LSR_DATA_READY)
	self.stats.rxBytes = self.stats.rxBytes + 1
	self:_updateIRQ()
end

function Uart8250:pushInput(text)
	for index = 1, #tostring(text) do
		self:pushInputByte(string.byte(text, index))
	end
end

function Uart8250:readOutput()
	local chars = {}
	for index = 1, #self._txLog do
		chars[index] = string.char(self._txLog[index])
	end
	return table.concat(chars)
end

function Uart8250:drainOutputBytes()
	local out = self._txLog
	self._txLog = {}
	return out
end

function Uart8250:getStats()
	return self.stats
end

return Uart8250
]]></string>
            </Properties>
