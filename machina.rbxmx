        <Item class="ModuleScript" referent="10">
          <Properties>
            <string name="Name">Assembler8086</string>
            <string name="Source"><![CDATA[local Assembler8086 = {}

local REG16 = {
	AX = 0,
	CX = 1,
	DX = 2,
	BX = 3,
	SP = 4,
	BP = 5,
	SI = 6,
	DI = 7,
}

local REG32 = {
	EAX = 0,
	ECX = 1,
	EDX = 2,
	EBX = 3,
	ESP = 4,
	EBP = 5,
	ESI = 6,
	EDI = 7,
}

local REG8 = {
	AL = 0,
	CL = 1,
	DL = 2,
	BL = 3,
	AH = 4,
	CH = 5,
	DH = 6,
	BH = 7,
}

local SEGREG = {
	ES = 0,
	CS = 1,
	SS = 2,
	DS = 3,
}

local MEM_BASE = {
	["BX+SI"] = 0,
	["BX+DI"] = 1,
	["BP+SI"] = 2,
	["BP+DI"] = 3,
	SI = 4,
	DI = 5,
	BP = 6,
	BX = 7,
}

local function trim(text)
	return (text:gsub("^%s+", ""):gsub("%s+$", ""))
end

local function upper(text)
	return string.upper(text)
end

local function stripComment(line)
	local inString = false
	local quote = nil
	for i = 1, #line do
		local ch = line:sub(i, i)
		if inString then
			if ch == quote then
				inString = false
				quote = nil
			elseif ch == "\\" then
				i = i + 1
			end
		elseif ch == '"' or ch == "'" then
			inString = true
			quote = ch
		elseif ch == ";" then
			return trim(line:sub(1, i - 1))
		end
	end
	return trim(line)
end

local function splitCsv(text)
	local out = {}
	local cur = {}
	local depth = 0
	local quote = nil
	local i = 1
	while i <= #text do
		local ch = text:sub(i, i)
		if quote then
			table.insert(cur, ch)
			if ch == quote then
				quote = nil
			elseif ch == "\\" and i < #text then
				i = i + 1
				table.insert(cur, text:sub(i, i))
			end
		elseif ch == '"' or ch == "'" then
			quote = ch
			table.insert(cur, ch)
		elseif ch == "[" then
			depth = depth + 1
			table.insert(cur, ch)
		elseif ch == "]" then
			depth = math.max(0, depth - 1)
			table.insert(cur, ch)
		elseif ch == "," and depth == 0 then
			table.insert(out, trim(table.concat(cur)))
			cur = {}
		else
			table.insert(cur, ch)
		end
		i = i + 1
	end
	if #cur > 0 then
		table.insert(out, trim(table.concat(cur)))
	end
	return out
end

local function parseNumber(text)
	if text:match("^0x[%da-fA-F]+$") then
		return tonumber(text)
	end
	if text:match("^%d+$") then
		return tonumber(text)
	end
	if text:match("^'.'$") then
		return string.byte(text:sub(2, 2))
	end
	return nil
end

local function evalExpr(expr, symbols, currentAddress, origin)
	local text = trim(expr or "")
	if text == "" then
		return 0
	end

	local total = 0
	local sign = 1
	local i = 1
	while i <= #text do
		while i <= #text and text:sub(i, i):match("%s") do
			i = i + 1
		end
		if i > #text then
			break
		end
		local ch = text:sub(i, i)
		if ch == "+" then
			sign = 1
			i = i + 1
		elseif ch == "-" then
			sign = -1
			i = i + 1
		else
			local j = i
			while j <= #text and not text:sub(j, j):match("[%+%-]") do
				j = j + 1
			end
			local term = trim(text:sub(i, j - 1))
			local value
			if term == "$" then
				value = currentAddress
			elseif term == "$$" then
				value = origin
			else
				value = parseNumber(term)
				if value == nil then
					value = symbols and symbols[upper(term)] or nil
				end
			end
			assert(value ~= nil, "Unknown symbol in expression: " .. tostring(term))
			total = total + sign * value
			sign = 1
			i = j
		end
	end

	return total
end

local function parseOperand(raw)
	local text = trim(raw or "")
	local width = nil
	local upperText = upper(text)
	if upperText:sub(1, 5) == "BYTE " then
		width = 8
		text = trim(text:sub(6))
		upperText = upper(text)
	elseif upperText:sub(1, 5) == "WORD " then
		width = 16
		text = trim(text:sub(6))
		upperText = upper(text)
	elseif upperText:sub(1, 6) == "DWORD " then
		width = 32
		text = trim(text:sub(7))
		upperText = upper(text)
	end

	if REG32[upperText] ~= nil then
		return { kind = "reg32", code = REG32[upperText], text = upperText }
	end
	if REG16[upperText] ~= nil then
		return { kind = "reg16", code = REG16[upperText], text = upperText }
	end
	if REG8[upperText] ~= nil then
		return { kind = "reg8", code = REG8[upperText], text = upperText }
	end
	if SEGREG[upperText] ~= nil then
		return { kind = "seg", code = SEGREG[upperText], text = upperText }
	end
	if text:sub(1, 1) == "[" and text:sub(-1) == "]" then
		local inner = trim(text:sub(2, -2))
		local base = MEM_BASE[upper(inner)]
		if base ~= nil then
			return { kind = "mem", base = base, mode = "base", width = width }
		end
		return { kind = "mem", expr = inner, mode = "direct", width = width }
	end
	return { kind = "imm", expr = text, width = width }
end

local function encodeWord(bytes, value)
	local v = (tonumber(value) or 0) % 0x10000
	bytes[#bytes + 1] = v % 256
	bytes[#bytes + 1] = math.floor(v / 256) % 256
end

local function encodeDword(bytes, value)
	local v = (tonumber(value) or 0) % 0x100000000
	bytes[#bytes + 1] = v % 256
	bytes[#bytes + 1] = math.floor(v / 256) % 256
	bytes[#bytes + 1] = math.floor(v / 0x10000) % 256
	bytes[#bytes + 1] = math.floor(v / 0x1000000) % 256
end

local function operandWidth(operand, default32)
	if not operand then
		return nil
	end
	if operand.kind == "reg8" then
		return 8
	end
	if operand.kind == "reg16" then
		return 16
	end
	if operand.kind == "reg32" then
		return 32
	end
	if operand.kind == "mem" and operand.width then
		return operand.width
	end
	if operand.kind == "mem" then
		return default32 and 32 or 16
	end
	return nil
end

local function needsOperandPrefix(width, default32)
	if width == nil or width == 8 then
		return false
	end
	if default32 then
		return width == 16
	end
	return width == 32
end

local function controlTransferWidth(operand, default32)
	if not operand then
		return default32 and 32 or 16
	end
	return operandWidth(operand, default32) or operand.width or (default32 and 32 or 16)
end

local function needsAddressPrefix(operand, default32)
	return default32 and operand and operand.kind == "mem"
end

local function emitPrefixes(bytes, addressOperand, width, default32)
	if needsAddressPrefix(addressOperand, default32) then
		bytes[#bytes + 1] = 0x67
	end
	if needsOperandPrefix(width, default32) then
		bytes[#bytes + 1] = 0x66
	end
end

local function modrm(mod, reg, rm)
	return bit32.bor(bit32.lshift(mod, 6), bit32.lshift(reg, 3), rm)
end

local function encodeMem(bytes, operand, regField, symbols, currentAddress, origin)
	if operand.mode == "direct" then
		bytes[#bytes + 1] = modrm(0, regField, 6)
		encodeWord(bytes, evalExpr(operand.expr, symbols, currentAddress, origin))
		return
	end

	local rm = operand.base
	if rm == 6 then
		bytes[#bytes + 1] = modrm(1, regField, rm)
		bytes[#bytes + 1] = 0
		return
	end
	bytes[#bytes + 1] = modrm(0, regField, rm)
end

local function memSize(operand)
	if operand.mode == "direct" then
		return 3
	end
	if operand.base == 6 then
		return 2
	end
	return 1
end

local function isCondJump(name)
	return name == "JE" or name == "JZ" or name == "JNE" or name == "JNZ" or name == "JC" or name == "JNC"
end

local function estimateInstruction(name, operands, default32)
	if
		name == "NOP"
		or name == "RET"
		or name == "RETF"
		or name == "IRET"
		or name == "CLI"
		or name == "STI"
		or name == "HLT"
	then
		return 1
	end
	if name == "INT" then
		return 2
	end
	if name == "IN" then
		local dst = operands[1]
		local src = operands[2]
		assert(dst and src, "Assembler8086: IN requires two operands")
		local dstWidth = operandWidth(dst, default32)
		local dstIsAccumulator = (dst.kind == "reg8" and dst.code == 0)
			or ((dstWidth == 16 or dstWidth == 32) and dst.code == 0)
		local srcIsPort = src.kind == "imm" or (src.kind == "reg16" and src.code == REG16.DX)
		assert(dstIsAccumulator and srcIsPort, "Assembler8086: supported IN forms are IN AL|AX|EAX, imm8|DX")
		return src.kind == "imm" and 2 or 1
	end
	if name == "OUT" then
		local dst = operands[1]
		local src = operands[2]
		assert(dst and src, "Assembler8086: OUT requires two operands")
		local dstIsPort = dst.kind == "imm" or (dst.kind == "reg16" and dst.code == REG16.DX)
		local srcWidth = operandWidth(src, default32)
		local srcIsAccumulator = (src.kind == "reg8" and src.code == 0)
			or ((srcWidth == 16 or srcWidth == 32) and src.code == 0)
		assert(dstIsPort and srcIsAccumulator, "Assembler8086: supported OUT forms are OUT imm8|DX, AL|AX|EAX")
		return dst.kind == "imm" and 2 or 1
	end
	if name == "LGDT" or name == "LIDT" then
		local op = operands[1]
		assert(op and op.kind == "mem", "Assembler8086: " .. name .. " requires a memory operand")
		return (needsAddressPrefix(op, default32) and 1 or 0) + 2 + memSize(op)
	end
	if name == "LMSW" or name == "SMSW" then
		local op = operands[1]
		assert(op and (op.kind == "reg16" or op.kind == "mem"), "Assembler8086: " .. name .. " requires r/m16")
		return (needsAddressPrefix(op, default32) and 1 or 0) + 2 + (op.kind == "mem" and memSize(op) or 1)
	end
	if name == "JMP" or name == "CALL" then
		local dst = operands[1]
		local width = controlTransferWidth(dst, default32)
		local prefix = needsOperandPrefix(width, default32) and 1 or 0
		local addressPrefix = needsAddressPrefix(dst, default32) and 1 or 0
		if dst and ((dst.kind == "reg16" or dst.kind == "reg32") or dst.kind == "mem") then
			return addressPrefix + prefix + 2 + (dst.kind == "mem" and (memSize(dst) - 1) or 0)
		end
		return prefix + 1 + (width == 32 and 4 or 2)
	end
	if isCondJump(name) then
		return default32 and 7 or 5
	end
	if name == "PUSH" or name == "POP" then
		local op = operands[1]
		local width = operandWidth(op, default32)
		local prefix = needsOperandPrefix(width, default32) and 1 or 0
		if op and op.kind == "imm" then
			return prefix + (default32 and 5 or 3)
		end
		return prefix + 1
	end
	if name == "INC" or name == "DEC" then
		local width = operandWidth(operands[1], default32)
		return (needsOperandPrefix(width, default32) and 1 or 0) + 1
	end
	if name == "DB" then
		local size = 0
		for _, operand in ipairs(operands) do
			if operand:match('^".*"$') then
				size = size + (#operand - 2)
			else
				size = size + 1
			end
		end
		return size
	end
	if name == "DW" then
		return #operands * 2
	end
	if name == "DD" then
		return #operands * 4
	end
	if name == "PADTO" then
		return 0
	end
	if name == "MOV" then
		local dst = operands[1]
		local src = operands[2]
		if not dst or not src then
			return 0
		end
		if (dst.kind == "reg16" or dst.kind == "reg32") and src.kind == "imm" then
			local width = operandWidth(dst, default32)
			return (needsOperandPrefix(width, default32) and 1 or 0) + 1 + (width == 32 and 4 or 2)
		end
		if dst.kind == "reg8" and src.kind == "imm" then
			return 2
		end
		if dst.kind == "seg" and src.kind == "reg16" then
			assert(dst.code ~= 1, "Assembler8086: MOV CS, r/m16 is not supported")
			return (default32 and 1 or 0) + 2
		end
		if dst.kind == "reg16" and src.kind == "seg" then
			return (default32 and 1 or 0) + 2
		end
		if
			(dst.kind == "reg16" or dst.kind == "reg32")
			and ((src.kind == "reg16" or src.kind == "reg32") or src.kind == "mem")
		then
			local width = operandWidth(dst, default32)
			return (needsAddressPrefix(src, default32) and 1 or 0)
				+ (needsOperandPrefix(width, default32) and 1 or 0)
				+ 1
				+ (src.kind == "mem" and memSize(src) or 1)
		end
		if dst.kind == "reg8" and (src.kind == "reg8" or src.kind == "mem") then
			return (needsAddressPrefix(src, default32) and 1 or 0) + 1 + (src.kind == "mem" and memSize(src) or 1)
		end
		if dst.kind == "mem" and (src.kind == "reg16" or src.kind == "reg32" or src.kind == "reg8") then
			local width = operandWidth(src, default32)
			return (needsAddressPrefix(dst, default32) and 1 or 0)
				+ (needsOperandPrefix(width, default32) and 1 or 0)
				+ 1
				+ memSize(dst)
		end
		if dst.kind == "mem" and src.kind == "imm" then
			local width = operandWidth(dst, default32)
			local immSize = width == 32 and 4 or width == 16 and 2 or 1
			return (needsAddressPrefix(dst, default32) and 1 or 0)
				+ (needsOperandPrefix(width, default32) and 1 or 0)
				+ 1
				+ memSize(dst)
				+ immSize
		end
	end
	if name == "ADD" or name == "SUB" then
		local dst = operands[1]
		local src = operands[2]
		if not dst or not src then
			return 0
		end
		assert(src.kind == "imm", "Assembler8086: only immediate ADD/SUB forms are supported")
		if dst.kind == "reg16" or dst.kind == "reg32" then
			local width = operandWidth(dst, default32)
			return (needsOperandPrefix(width, default32) and 1 or 0) + 2 + (width == 32 and 4 or 2)
		end
		if dst.kind == "reg8" then
			return 3
		end
		if dst.kind == "mem" then
			local width = operandWidth(dst, default32)
			local immSize = width == 32 and 4 or width == 16 and 2 or 1
			return (needsAddressPrefix(dst, default32) and 1 or 0)
				+ (needsOperandPrefix(width, default32) and 1 or 0)
				+ 1
				+ memSize(dst)
				+ immSize
		end
	end
	if name == "CMP" then
		local dst = operands[1]
		local src = operands[2]
		if not dst or not src then
			return 0
		end
		if src.kind == "imm" then
			if dst.kind == "reg16" or dst.kind == "reg32" then
				local width = operandWidth(dst, default32)
				return (needsOperandPrefix(width, default32) and 1 or 0) + 2 + (width == 32 and 4 or 2)
			end
			if dst.kind == "reg8" then
				return 3
			end
			if dst.kind == "mem" then
				local width = operandWidth(dst, default32)
				local immSize = width == 32 and 4 or width == 16 and 2 or 1
				return (needsAddressPrefix(dst, default32) and 1 or 0)
					+ (needsOperandPrefix(width, default32) and 1 or 0)
					+ 1
					+ memSize(dst)
					+ immSize
			end
		end
		if (dst.kind == "reg16" or dst.kind == "reg32") and (src.kind == "reg16" or src.kind == "reg32") then
			local width = operandWidth(dst, default32)
			return (needsOperandPrefix(width, default32) and 1 or 0) + 2
		end
		if dst.kind == "reg8" and src.kind == "reg8" then
			return 2
		end
		if (dst.kind == "reg16" or dst.kind == "reg32") and src.kind == "mem" then
			local width = operandWidth(dst, default32)
			return (needsAddressPrefix(src, default32) and 1 or 0)
				+ (needsOperandPrefix(width, default32) and 1 or 0)
				+ 1
				+ memSize(src)
		end
		if dst.kind == "reg8" and src.kind == "mem" then
			return (needsAddressPrefix(src, default32) and 1 or 0) + 1 + memSize(src)
		end
		if dst.kind == "mem" and (src.kind == "reg16" or src.kind == "reg32") then
			local width = operandWidth(src, default32)
			return (needsAddressPrefix(dst, default32) and 1 or 0)
				+ (needsOperandPrefix(width, default32) and 1 or 0)
				+ 1
				+ memSize(dst)
		end
		if dst.kind == "mem" and src.kind == "reg8" then
			return (needsAddressPrefix(dst, default32) and 1 or 0) + 1 + memSize(dst)
		end
	end
	if name == "XOR" then
		local dst = operands[1]
		local src = operands[2]
		if not dst or not src then
			return 0
		end
		if (dst.kind == "reg16" or dst.kind == "reg32") and (src.kind == "reg16" or src.kind == "reg32") then
			local width = operandWidth(dst, default32)
			return (needsOperandPrefix(width, default32) and 1 or 0) + 2
		end
		if dst.kind == "reg8" and src.kind == "reg8" then
			return 2
		end
		assert(false, "Assembler8086: only register XOR forms are supported")
	end
	error("Assembler8086: cannot estimate instruction " .. tostring(name))
end

local function parseLine(line)
	local text = stripComment(line)
	if text == "" then
		return nil
	end

	local labels = {}
	while true do
		local label, rest = text:match("^([%a_][%w_]*):%s*(.*)$")
		if not label then
			break
		end
		table.insert(labels, upper(label))
		text = rest
	end

	if text == "" then
		return { labels = labels }
	end

	local mnemonic, rest = text:match("^(%S+)%s*(.*)$")
	local name = upper(mnemonic)
	local operandsText = rest ~= "" and splitCsv(rest) or {}
	local operands = {}
	if name == "DB" or name == "DW" or name == "DD" or name == "PADTO" or name == "ORG" then
		operands = operandsText
	else
		for _, operand in ipairs(operandsText) do
			table.insert(operands, parseOperand(operand))
		end
	end

	return {
		labels = labels,
		name = name,
		operands = operands,
		rawOperands = operandsText,
	}
end

local function appendTextBytes(bytes, operand, symbols, currentAddress, origin)
	if operand:match('^".*"$') then
		local text = operand:sub(2, -2)
		text = text:gsub("\\n", "\n"):gsub("\\r", "\r"):gsub("\\t", "\t")
		for i = 1, #text do
			bytes[#bytes + 1] = string.byte(text, i)
		end
	else
		bytes[#bytes + 1] = evalExpr(operand, symbols, currentAddress, origin) % 256
	end
end

local function encodeGroupImm(bytes, opcode8, opcode16, subcode, dst, src, symbols, currentAddress, origin, default32)
	local value = evalExpr(src.expr, symbols, currentAddress, origin)
	local width = operandWidth(dst, default32) or 8
	emitPrefixes(bytes, dst.kind == "mem" and dst or nil, width, default32)
	if width == 16 or width == 32 then
		bytes[#bytes + 1] = opcode16
		if dst.kind == "reg16" or dst.kind == "reg32" then
			bytes[#bytes + 1] = modrm(3, subcode, dst.code)
		else
			encodeMem(bytes, dst, subcode, symbols, currentAddress, origin)
		end
		if width == 32 then
			encodeDword(bytes, value)
		else
			encodeWord(bytes, value)
		end
	else
		bytes[#bytes + 1] = opcode8
		if dst.kind == "reg8" then
			bytes[#bytes + 1] = modrm(3, subcode, dst.code)
		else
			encodeMem(bytes, dst, subcode, symbols, currentAddress, origin)
		end
		bytes[#bytes + 1] = value % 256
	end
end

local function encodeInstruction(inst, bytes, symbols, currentAddress, origin, default32)
	local name = inst.name
	local operands = inst.operands
	if name == "ORG" then
		return "ORG"
	end
	if name == "DB" then
		for _, operand in ipairs(inst.rawOperands) do
			appendTextBytes(bytes, operand, symbols, currentAddress, origin)
		end
		return
	end
	if name == "DW" then
		for _, operand in ipairs(inst.rawOperands) do
			encodeWord(bytes, evalExpr(operand, symbols, currentAddress, origin))
		end
		return
	end
	if name == "DD" then
		for _, operand in ipairs(inst.rawOperands) do
			encodeDword(bytes, evalExpr(operand, symbols, currentAddress, origin))
		end
		return
	end
	if name == "PADTO" then
		local target = evalExpr(inst.rawOperands[1], symbols, currentAddress, origin)
		local fill = inst.rawOperands[2] and evalExpr(inst.rawOperands[2], symbols, currentAddress, origin) or 0
		while origin + #bytes < target do
			bytes[#bytes + 1] = fill % 256
		end
		return
	end
	if name == "NOP" then
		bytes[#bytes + 1] = 0x90
		return
	end
	if name == "CLI" then
		bytes[#bytes + 1] = 0xFA
		return
	end
	if name == "STI" then
		bytes[#bytes + 1] = 0xFB
		return
	end
	if name == "HLT" then
		bytes[#bytes + 1] = 0xF4
		return
	end
	if name == "RET" then
		bytes[#bytes + 1] = 0xC3
		return
	end
	if name == "RETF" then
		bytes[#bytes + 1] = 0xCB
		return
	end
	if name == "IRET" then
		bytes[#bytes + 1] = 0xCF
		return
	end
	if name == "INT" then
		bytes[#bytes + 1] = 0xCD
		bytes[#bytes + 1] = evalExpr(operands[1].expr, symbols, currentAddress, origin) % 256
		return
	end
	if name == "LGDT" or name == "LIDT" then
		local op = operands[1]
		local regField = name == "LGDT" and 2 or 3
		if needsAddressPrefix(op, default32) then
			bytes[#bytes + 1] = 0x67
		end
		bytes[#bytes + 1] = 0x0F
		bytes[#bytes + 1] = 0x01
		encodeMem(bytes, op, regField, symbols, currentAddress, origin)
		return
	end
	if name == "SMSW" or name == "LMSW" then
		local op = operands[1]
		local regField = name == "SMSW" and 4 or 6
		if needsAddressPrefix(op, default32) then
			bytes[#bytes + 1] = 0x67
		end
		bytes[#bytes + 1] = 0x0F
		bytes[#bytes + 1] = 0x01
		if op.kind == "reg16" then
			bytes[#bytes + 1] = modrm(3, regField, op.code)
		else
			encodeMem(bytes, op, regField, symbols, currentAddress, origin)
		end
		return
	end
	if name == "IN" then
		local dst = operands[1]
		local src = operands[2]
		local width = operandWidth(dst, default32)
		local dstIsWord = (width == 16 or width == 32) and dst.code == 0
		if needsOperandPrefix(width, default32) then
			bytes[#bytes + 1] = 0x66
		end
		if src.kind == "imm" then
			bytes[#bytes + 1] = dstIsWord and 0xE5 or 0xE4
			bytes[#bytes + 1] = evalExpr(src.expr, symbols, currentAddress, origin) % 256
			return
		end
		assert(src.kind == "reg16" and src.code == REG16.DX, "Assembler8086: supported IN forms are IN AL|AX, imm8|DX")
		bytes[#bytes + 1] = dstIsWord and 0xED or 0xEC
		return
	end
	if name == "OUT" then
		local dst = operands[1]
		local src = operands[2]
		local width = operandWidth(src, default32)
		local srcIsWord = (width == 16 or width == 32) and src.code == 0
		if needsOperandPrefix(width, default32) then
			bytes[#bytes + 1] = 0x66
		end
		if dst.kind == "imm" then
			bytes[#bytes + 1] = srcIsWord and 0xE7 or 0xE6
			bytes[#bytes + 1] = evalExpr(dst.expr, symbols, currentAddress, origin) % 256
			return
		end
		assert(
			dst.kind == "reg16" and dst.code == REG16.DX,
			"Assembler8086: supported OUT forms are OUT imm8|DX, AL|AX"
		)
		bytes[#bytes + 1] = srcIsWord and 0xEF or 0xEE
		return
	end
	if name == "PUSH" then
		local op = operands[1]
		local width = operandWidth(op, default32)
		if needsOperandPrefix(width, default32) then
			bytes[#bytes + 1] = 0x66
		end
		if op.kind == "reg16" or op.kind == "reg32" then
			bytes[#bytes + 1] = 0x50 + op.code
		else
			bytes[#bytes + 1] = 0x68
			if width == 32 then
				encodeDword(bytes, evalExpr(op.expr, symbols, currentAddress, origin))
			else
				encodeWord(bytes, evalExpr(op.expr, symbols, currentAddress, origin))
			end
		end
		return
	end
	if name == "POP" then
		local width = operandWidth(operands[1], default32)
		if needsOperandPrefix(width, default32) then
			bytes[#bytes + 1] = 0x66
		end
		bytes[#bytes + 1] = 0x58 + operands[1].code
		return
	end
	if name == "INC" then
		local width = operandWidth(operands[1], default32)
		if needsOperandPrefix(width, default32) then
			bytes[#bytes + 1] = 0x66
		end
		bytes[#bytes + 1] = 0x40 + operands[1].code
		return
	end
	if name == "DEC" then
		local width = operandWidth(operands[1], default32)
		if needsOperandPrefix(width, default32) then
			bytes[#bytes + 1] = 0x66
		end
		bytes[#bytes + 1] = 0x48 + operands[1].code
		return
	end
	if name == "JMP" then
		local op = operands[1]
		local width = controlTransferWidth(op, default32)
		emitPrefixes(bytes, op.kind == "mem" and op or nil, width, default32)
		if op.kind == "reg16" or op.kind == "reg32" then
			bytes[#bytes + 1] = 0xFF
			bytes[#bytes + 1] = modrm(3, 4, op.code)
		elseif op.kind == "mem" then
			bytes[#bytes + 1] = 0xFF
			encodeMem(bytes, op, 4, symbols, currentAddress, origin)
		else
			local target = evalExpr(op.expr, symbols, currentAddress, origin)
			local rel = target
				- (currentAddress + (needsOperandPrefix(width, default32) and 1 or 0) + 1 + (width == 32 and 4 or 2))
			bytes[#bytes + 1] = 0xE9
			if width == 32 then
				encodeDword(bytes, rel)
			else
				encodeWord(bytes, rel)
			end
		end
		return
	end
	if name == "CALL" then
		local op = operands[1]
		local width = controlTransferWidth(op, default32)
		emitPrefixes(bytes, op.kind == "mem" and op or nil, width, default32)
		if op.kind == "reg16" or op.kind == "reg32" then
			bytes[#bytes + 1] = 0xFF
			bytes[#bytes + 1] = modrm(3, 2, op.code)
		elseif op.kind == "mem" then
			bytes[#bytes + 1] = 0xFF
			encodeMem(bytes, op, 2, symbols, currentAddress, origin)
		else
			local target = evalExpr(op.expr, symbols, currentAddress, origin)
			local rel = target
				- (currentAddress + (needsOperandPrefix(width, default32) and 1 or 0) + 1 + (width == 32 and 4 or 2))
			bytes[#bytes + 1] = 0xE8
			if width == 32 then
				encodeDword(bytes, rel)
			else
				encodeWord(bytes, rel)
			end
		end
		return
	end
	if isCondJump(name) then
		local inverseOpcode = ({
			JE = 0x75,
			JZ = 0x75,
			JNE = 0x74,
			JNZ = 0x74,
			JC = 0x73,
			JNC = 0x72,
		})[name]
		local target = evalExpr(operands[1].expr, symbols, currentAddress, origin)
		local rel = target - (currentAddress + (default32 and 7 or 5))
		bytes[#bytes + 1] = inverseOpcode
		bytes[#bytes + 1] = default32 and 0x05 or 0x03
		bytes[#bytes + 1] = 0xE9
		if default32 then
			encodeDword(bytes, rel)
		else
			encodeWord(bytes, rel)
		end
		return
	end
	if name == "MOV" then
		local dst = operands[1]
		local src = operands[2]
		if (dst.kind == "reg16" or dst.kind == "reg32") and src.kind == "imm" then
			local width = operandWidth(dst, default32)
			if needsOperandPrefix(width, default32) then
				bytes[#bytes + 1] = 0x66
			end
			bytes[#bytes + 1] = 0xB8 + dst.code
			if width == 32 then
				encodeDword(bytes, evalExpr(src.expr, symbols, currentAddress, origin))
			else
				encodeWord(bytes, evalExpr(src.expr, symbols, currentAddress, origin))
			end
			return
		end
		if dst.kind == "reg8" and src.kind == "imm" then
			bytes[#bytes + 1] = 0xB0 + dst.code
			bytes[#bytes + 1] = evalExpr(src.expr, symbols, currentAddress, origin) % 256
			return
		end
		if dst.kind == "seg" and src.kind == "reg16" then
			assert(dst.code ~= 1, "Assembler8086: MOV CS, r/m16 is not supported")
			if default32 then
				bytes[#bytes + 1] = 0x66
			end
			bytes[#bytes + 1] = 0x8E
			bytes[#bytes + 1] = modrm(3, dst.code, src.code)
			return
		end
		if dst.kind == "reg16" and src.kind == "seg" then
			if default32 then
				bytes[#bytes + 1] = 0x66
			end
			bytes[#bytes + 1] = 0x8C
			bytes[#bytes + 1] = modrm(3, src.code, dst.code)
			return
		end
		if (dst.kind == "reg16" or dst.kind == "reg32") and (src.kind == "reg16" or src.kind == "reg32") then
			local width = operandWidth(dst, default32)
			emitPrefixes(bytes, nil, width, default32)
			bytes[#bytes + 1] = 0x8B
			bytes[#bytes + 1] = modrm(3, dst.code, src.code)
			return
		end
		if dst.kind == "reg8" and src.kind == "reg8" then
			bytes[#bytes + 1] = 0x8A
			bytes[#bytes + 1] = modrm(3, dst.code, src.code)
			return
		end
		if (dst.kind == "reg16" or dst.kind == "reg32") and src.kind == "mem" then
			local width = operandWidth(dst, default32)
			emitPrefixes(bytes, src, width, default32)
			bytes[#bytes + 1] = 0x8B
			encodeMem(bytes, src, dst.code, symbols, currentAddress, origin)
			return
		end
		if dst.kind == "reg8" and src.kind == "mem" then
			emitPrefixes(bytes, src, 8, default32)
			bytes[#bytes + 1] = 0x8A
			encodeMem(bytes, src, dst.code, symbols, currentAddress, origin)
			return
		end
		if dst.kind == "mem" and (src.kind == "reg16" or src.kind == "reg32") then
			local width = operandWidth(src, default32)
			emitPrefixes(bytes, dst, width, default32)
			bytes[#bytes + 1] = 0x89
			encodeMem(bytes, dst, src.code, symbols, currentAddress, origin)
			return
		end
		if dst.kind == "mem" and src.kind == "reg8" then
			emitPrefixes(bytes, dst, 8, default32)
			bytes[#bytes + 1] = 0x88
			encodeMem(bytes, dst, src.code, symbols, currentAddress, origin)
			return
		end
		if dst.kind == "mem" and src.kind == "imm" then
			local width = operandWidth(dst, default32)
			emitPrefixes(bytes, dst, width, default32)
			if width == 32 then
				bytes[#bytes + 1] = 0xC7
				encodeMem(bytes, dst, 0, symbols, currentAddress, origin)
				encodeDword(bytes, evalExpr(src.expr, symbols, currentAddress, origin))
			elseif width == 16 then
				bytes[#bytes + 1] = 0xC7
				encodeMem(bytes, dst, 0, symbols, currentAddress, origin)
				encodeWord(bytes, evalExpr(src.expr, symbols, currentAddress, origin))
			else
				bytes[#bytes + 1] = 0xC6
				encodeMem(bytes, dst, 0, symbols, currentAddress, origin)
				bytes[#bytes + 1] = evalExpr(src.expr, symbols, currentAddress, origin) % 256
			end
			return
		end
	end
	if name == "ADD" then
		local dst = operands[1]
		local src = operands[2]
		if src.kind == "imm" then
			encodeGroupImm(bytes, 0x80, 0x81, 0, dst, src, symbols, currentAddress, origin, default32)
			return
		end
	end
	if name == "SUB" then
		local dst = operands[1]
		local src = operands[2]
		if src.kind == "imm" then
			encodeGroupImm(bytes, 0x80, 0x81, 5, dst, src, symbols, currentAddress, origin, default32)
			return
		end
	end
	if name == "CMP" then
		local dst = operands[1]
		local src = operands[2]
		if src.kind == "imm" then
			encodeGroupImm(bytes, 0x80, 0x81, 7, dst, src, symbols, currentAddress, origin, default32)
			return
		end
		if (dst.kind == "reg16" or dst.kind == "reg32") and (src.kind == "reg16" or src.kind == "reg32") then
			local width = operandWidth(dst, default32)
			emitPrefixes(bytes, nil, width, default32)
			bytes[#bytes + 1] = 0x3B
			bytes[#bytes + 1] = modrm(3, dst.code, src.code)
			return
		end
		if dst.kind == "reg8" and src.kind == "reg8" then
			bytes[#bytes + 1] = 0x3A
			bytes[#bytes + 1] = modrm(3, dst.code, src.code)
			return
		end
		if (dst.kind == "reg16" or dst.kind == "reg32") and src.kind == "mem" then
			local width = operandWidth(dst, default32)
			emitPrefixes(bytes, src, width, default32)
			bytes[#bytes + 1] = 0x3B
			encodeMem(bytes, src, dst.code, symbols, currentAddress, origin)
			return
		end
		if dst.kind == "reg8" and src.kind == "mem" then
			emitPrefixes(bytes, src, 8, default32)
			bytes[#bytes + 1] = 0x3A
			encodeMem(bytes, src, dst.code, symbols, currentAddress, origin)
			return
		end
		if dst.kind == "mem" and (src.kind == "reg16" or src.kind == "reg32") then
			local width = operandWidth(src, default32)
			emitPrefixes(bytes, dst, width, default32)
			bytes[#bytes + 1] = 0x39
			encodeMem(bytes, dst, src.code, symbols, currentAddress, origin)
			return
		end
		if dst.kind == "mem" and src.kind == "reg8" then
			emitPrefixes(bytes, dst, 8, default32)
			bytes[#bytes + 1] = 0x38
			encodeMem(bytes, dst, src.code, symbols, currentAddress, origin)
			return
		end
	end
	if name == "XOR" then
		local dst = operands[1]
		local src = operands[2]
		if (dst.kind == "reg16" or dst.kind == "reg32") and (src.kind == "reg16" or src.kind == "reg32") then
			local width = operandWidth(dst, default32)
			if needsOperandPrefix(width, default32) then
				bytes[#bytes + 1] = 0x66
			end
			bytes[#bytes + 1] = 0x33
			bytes[#bytes + 1] = modrm(3, dst.code, src.code)
			return
		end
		if dst.kind == "reg8" and src.kind == "reg8" then
			bytes[#bytes + 1] = 0x32
			bytes[#bytes + 1] = modrm(3, dst.code, src.code)
			return
		end
	end

	error("Assembler8086: unsupported instruction " .. tostring(name))
end

function Assembler8086.compile(source, opts)
	opts = opts or {}
	local lines = {}
	for line in (source .. "\n"):gmatch("([^\n]*)\n") do
		local parsed = parseLine(line)
		if parsed then
			table.insert(lines, parsed)
		end
	end

	local origin = opts.origin or 0
	local defaultOperand32 = opts.defaultOperand32 == true
	local address = origin
	local symbols = {}

	for _, inst in ipairs(lines) do
		for _, label in ipairs(inst.labels or {}) do
			symbols[label] = address
		end
		if inst.name == "ORG" then
			origin = evalExpr(inst.rawOperands[1], symbols, address, origin)
			address = origin
		elseif inst.name == "PADTO" then
			address = math.max(address, evalExpr(inst.rawOperands[1], symbols, address, origin))
		elseif inst.name then
			address = address + estimateInstruction(inst.name, inst.operands, defaultOperand32)
		end
	end

	local bytes = {}
	origin = opts.origin or 0
	address = origin
	for _, inst in ipairs(lines) do
		if inst.name == "ORG" then
			origin = evalExpr(inst.rawOperands[1], symbols, address, origin)
			address = origin
		elseif inst.name then
			local before = #bytes
			encodeInstruction(inst, bytes, symbols, address, origin, defaultOperand32)
			address = address + (#bytes - before)
		end
	end

	return {
		bytes = bytes,
		symbols = symbols,
		origin = origin,
	}
end

return Assembler8086
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="11">
          <Properties>
            <string name="Name">BiosInterrupts</string>
            <string name="Source"><![CDATA[local BiosInterrupts = {}
BiosInterrupts.__index = BiosInterrupts

local function scanCodeForChar(ch)
	if ch == "\n" or ch == "\r" then
		return 0x1C
	end
	if ch == "\b" then
		return 0x0E
	end
	return 0
end

local function biosCharValue(ch)
	if ch == "\n" or ch == "\r" then
		return 13
	end
	if ch == "\b" then
		return 8
	end
	return string.byte(ch)
end

function BiosInterrupts.new(machine, runtime, image)
	local self = setmetatable({}, BiosInterrupts)
	self.machine = machine
	self.runtime = runtime
	self.image = image or {}
	self.config = machine.config
	self.x86 = machine.config.X86 or {}
	self._keyboardLatch = nil
	return self
end

function BiosInterrupts:_setCarry(cpu, enabled)
	cpu:setFlag(0x0001, enabled)
end

function BiosInterrupts:_setDiskStatus(cpu, status)
	cpu:setReg8(4, status % 0x100)
end

function BiosInterrupts:_teletype(cpu)
	local ch = cpu:getReg8(0)
	self.machine.gpu:print(string.char(ch == 0 and 32 or ch), 0x07)
	self:_setCarry(cpu, false)
end

function BiosInterrupts:_setVideoMode(cpu)
	local mode = cpu:getReg8(0)
	if mode == 0x03 then
		self.machine.gpu:setMode("TEXT")
		self.machine.gpu:clearScreen(0x07)
	end
	self:_setCarry(cpu, false)
end

function BiosInterrupts:_chsToLba(cylinder, head, sector)
	local spt = self.x86.SECTORS_PER_TRACK or 18
	local heads = self.x86.HEADS or 1
	if sector <= 0 or sector > spt or head < 0 or head >= heads or cylinder < 0 then
		return nil
	end
	return ((cylinder * heads + head) * spt) + (sector - 1)
end

function BiosInterrupts:_readSectors(cpu)
	local count = cpu:getReg8(0)
	local cl = cpu:getReg8(1)
	local cylinder = bit32.bor(cpu:getReg8(5), bit32.lshift(bit32.band(cl, 0xC0), 2))
	local sector = bit32.band(cl, 0x3F)
	local head = cpu:getReg8(6)
	local drive = cpu:getReg8(2)
	local bufferAddress = cpu:linearAddress(cpu.seg.ES, cpu:getReg16(3))

	if drive ~= (self.x86.BOOT_DRIVE or 0x80) then
		self:_setCarry(cpu, true)
		self:_setDiskStatus(cpu, 0x01)
		return true
	end

	local startLba = self:_chsToLba(cylinder, head, sector)
	if not startLba then
		self:_setCarry(cpu, true)
		self:_setDiskStatus(cpu, 0x04)
		return true
	end
	local totalSectors = self.machine.hdd.getTotalSectors and self.machine.hdd:getTotalSectors()
		or self.machine.hdd.totalSectors
	if (startLba + math.max(0, count - 1)) >= (tonumber(totalSectors) or 0) then
		self:_setCarry(cpu, true)
		self:_setDiskStatus(cpu, 0x04)
		return true
	end

	for sectorIndex = 0, math.max(0, count - 1) do
		local bytes = self.machine.hdd:readSector(startLba + sectorIndex)
		for i = 1, #bytes do
			cpu:writePhysical8(bufferAddress + sectorIndex * 512 + i - 1, bytes[i])
		end
	end

	if self.runtime and type(self.runtime.onDiskRead) == "function" then
		self.runtime:onDiskRead(startLba, count, bufferAddress)
	end

	self:_setCarry(cpu, false)
	self:_setDiskStatus(cpu, 0x00)
	cpu:setReg8(0, count)
	return true
end

function BiosInterrupts:_diskInterrupt(cpu)
	local service = cpu:getReg8(4)
	if service == 0x00 then
		self:_setCarry(cpu, false)
		self:_setDiskStatus(cpu, 0x00)
		return true
	end
	if service == 0x02 then
		return self:_readSectors(cpu)
	end
	self:_setCarry(cpu, true)
	self:_setDiskStatus(cpu, 0x01)
	return true
end

function BiosInterrupts:_keyboardInterrupt(cpu)
	local service = cpu:getReg8(4)
	if service == 0x00 then
		local ch = self._keyboardLatch
		if ch then
			local queued = self.machine.keyboard:peekChar()
			if queued == ch then
				self.machine.keyboard:readChar()
			end
			self._keyboardLatch = nil
		else
			ch = self.machine.keyboard:readChar()
		end
		if not ch then
			self:_setCarry(cpu, false)
			cpu:setFlag(0x0040, true)
			cpu:setReg8(0, 0)
			cpu:setReg8(4, 0)
			return true
		end
		cpu:setReg8(0, biosCharValue(ch))
		cpu:setReg8(4, scanCodeForChar(ch))
		cpu:setFlag(0x0040, false)
		self:_setCarry(cpu, false)
		return true
	end
	if service == 0x01 then
		local ch = self._keyboardLatch or self.machine.keyboard:peekChar()
		if ch then
			self._keyboardLatch = ch
			cpu:setReg8(0, biosCharValue(ch))
			cpu:setReg8(4, scanCodeForChar(ch))
			cpu:setFlag(0x0040, false)
		else
			self._keyboardLatch = nil
			cpu:setFlag(0x0040, true)
		end
		self:_setCarry(cpu, false)
		return true
	end
	return false
end

function BiosInterrupts:_clockInterrupt(cpu)
	local service = cpu:getReg8(4)
	if service == 0x00 then
		local rtc = self.machine.rtc
		local ticks = (rtc and rtc.getBIOSClockTicks and rtc:getBIOSClockTicks())
			or math.floor((os.clock() - (self.machine._uptimeStart or os.clock())) * 18.2)
		cpu:setReg16(1, math.floor(ticks / 0x10000))
		cpu:setReg16(2, ticks % 0x10000)
		self:_setCarry(cpu, false)
		return true
	end
	if service == 0x02 or service == 0x04 then
		local rtc = self.machine.rtc
		if not rtc or type(rtc.readRegister) ~= "function" then
			self:_setCarry(cpu, true)
			return true
		end
		local isDate = service == 0x04
		local regs = isDate and { 0x09, 0x08, 0x07 } or { 0x04, 0x02, 0x00 }
		cpu:setReg8(6, rtc:readRegister(regs[1]))
		cpu:setReg8(2, rtc:readRegister(regs[2]))
		cpu:setReg8(0, rtc:readRegister(regs[3]))
		self:_setCarry(cpu, false)
		return true
	end
	return false
end

function BiosInterrupts:_bootInterrupt(cpu)
	cpu.halted = true
	local reboot = function()
		self.machine:reboot()
	end
	if task and task.delay then
		task.delay(0, reboot)
	else
		reboot()
	end
	return true
end

function BiosInterrupts:handleInterrupt(cpu, vector)
	if vector == 0x10 then
		local service = cpu:getReg8(4)
		if service == 0x0E then
			self:_teletype(cpu)
			return true
		end
		if service == 0x00 then
			self:_setVideoMode(cpu)
			return true
		end
		return true
	end
	if vector == 0x13 then
		return self:_diskInterrupt(cpu)
	end
	if vector == 0x16 then
		return self:_keyboardInterrupt(cpu)
	end
	if vector == 0x19 then
		return self:_bootInterrupt(cpu)
	end
	if vector == 0x1A then
		return self:_clockInterrupt(cpu)
	end
	return false
end

return BiosInterrupts
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="12">
          <Properties>
            <string name="Name">BiosRom</string>
            <string name="Source"><![CDATA[local Assembler8086 = require(script.Parent.Assembler8086)

local BiosRom = {}

local function buildSource(config)
	local x86 = config.X86 or {}
	local bootDrive = x86.BOOT_DRIVE or 0x80
	return table.concat({
		"ORG 0x0100",
		"START:",
		"  CLI",
		"  XOR AX, AX",
		"  MOV ES, AX",
		"  MOV SS, AX",
		"  MOV SP, 0x7C00",
		"  MOV AX, 0xF000",
		"  MOV DS, AX",
		"  MOV AX, 0x0003",
		"  INT 0x10",
		"  MOV SI, BIOS_BANNER",
		"  CALL PRINT_STRING",
		"  MOV AX, 0x0000",
		"  MOV DS, AX",
		"  MOV ES, AX",
		"  MOV BX, 0x7C00",
		"  MOV AX, 0x0201",
		"  MOV CX, 0x0001",
		"  MOV DX, " .. string.format("0x%04X", bootDrive),
		"  INT 0x13",
		"  JC BOOT_FAIL",
		"  PUSH 0x0000",
		"  PUSH 0x7C00",
		"  RETF",
		"BOOT_FAIL:",
		"  MOV AX, 0xF000",
		"  MOV DS, AX",
		"  MOV SI, BOOT_FAIL_MSG",
		"  CALL PRINT_STRING",
		"BOOT_HANG:",
		"  HLT",
		"  JMP BOOT_HANG",
		"PRINT_STRING:",
		"  MOV AL, [SI]",
		"  CMP AL, 0",
		"  JE PRINT_DONE",
		"  MOV AH, 0x0E",
		"  INT 0x10",
		"  INC SI",
		"  JMP PRINT_STRING",
		"PRINT_DONE:",
		"  RET",
		"BIOS_BANNER:",
		'  DB "Machina x86 BIOS", 13, 10, 0',
		"BOOT_FAIL_MSG:",
		'  DB "Boot failed", 13, 10, 0',
	}, "\n")
end

function BiosRom.buildArtifact(config)
	return Assembler8086.compile(buildSource(config))
end

function BiosRom.buildROMBytes(config, artifact)
	local x86 = config.X86 or {}
	local romSize = x86.ROM_SIZE or 0x10000
	local romBytes = {}
	for index = 1, romSize do
		romBytes[index] = 0xFF
	end

	for index, byte in ipairs((artifact and artifact.bytes) or {}) do
		local target = ((artifact.origin or 0) + index)
		if target >= 1 and target <= romSize then
			romBytes[target] = byte
		end
	end

	local resetOffset = ((x86.RESET_VECTOR_OFF or 0xFFF0) + 1)
	romBytes[resetOffset] = 0xEA
	romBytes[resetOffset + 1] = (x86.BIOS_ENTRY_OFFSET or 0x0100) % 256
	romBytes[resetOffset + 2] = math.floor((x86.BIOS_ENTRY_OFFSET or 0x0100) / 256) % 256
	romBytes[resetOffset + 3] = (x86.RESET_VECTOR_SEG or 0xF000) % 256
	romBytes[resetOffset + 4] = math.floor((x86.RESET_VECTOR_SEG or 0xF000) / 256) % 256

	return romBytes
end

return BiosRom
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="13">
          <Properties>
            <string name="Name">BootController</string>
            <string name="Source"><![CDATA[local BiosInterrupts = require(script.Parent.BiosInterrupts)
local HardwareDiagnostics = require(script.Parent.HardwareDiagnostics)
local BootImageLoader = require(script.Parent.BootImageLoader)

local BootController = {}
BootController.__index = BootController

function BootController.new(machine)
	local self = setmetatable({}, BootController)
	self.machine = machine
	self.config = machine.config
	self.x86 = machine.config.X86 or {}
	self.image = nil
	self.bios = nil
	self._kernelLinear = ((self.x86.KERNEL_LOAD_SEG or 0x1000) * 16) + (self.x86.KERNEL_LOAD_OFF or 0)
	self._bootLinear = ((self.x86.BOOT_SECTOR_LOAD_SEG or 0) * 16) + (self.x86.BOOT_SECTOR_LOAD_OFF or 0x7C00)
	self._readyFlagLinear = nil
	return self
end

function BootController:startBoot()
	self.machine:_setBootStage("BIOS")
	self.machine.gpu:setMode("TEXT")
	self.machine.gpu:clearScreen(0x07)

	if self.machine.bus and self.machine.bus.timer then
		self.machine.bus.timer._enabled = false
		self.machine.bus.timer._irqEnabled = false
	end

	local ok, imageOrErr = pcall(function()
		return BootImageLoader.load(self.config)
	end)
	if not ok then
		self.machine:_setBootStage("FAULT", tostring(imageOrErr))
		self.machine.gpu:println("x86 image build failed", 0x0C)
		self.machine.gpu:println(tostring(imageOrErr), 0x0C)
		return
	end

	self.image = imageOrErr
	self.machine.hdd._sectors = {}
	for lba, sector in pairs(self.image.sectors) do
		self.machine.hdd:writeSector(lba, sector)
	end

	self.machine.rom:flash(self.image.romBytes)
	self.machine.cpu:reset()

	local diagnostics = nil
	local diagnosticsConfig = (self.x86 and self.x86.DIAGNOSTICS) or {}
	if diagnosticsConfig.ENABLED ~= false then
		self.machine:_setBootStage("DIAG")
		diagnostics = HardwareDiagnostics.run(self.machine, self.config)
		if diagnosticsConfig.PRINT_SUMMARY ~= false then
			local color = diagnostics.passed and 0x0A or 0x0E
			self.machine.gpu:println(
				string.format("Device diagnostics %d/%d", diagnostics.passedCount, diagnostics.totalCount),
				color
			)
		end
		self.machine.cpu:reset()
	end
	if self.machine.bus and self.machine.bus.timer then
		self.machine.bus.timer._enabled = true
		self.machine.bus.timer._irqEnabled = true
	end

	self.bios = BiosInterrupts.new(self.machine, self, self.image)
	self.machine.cpu:attachBIOS(self.bios)
	local kernelSymbols = self.image.symbols and self.image.symbols.kernel or nil
	local readyFlagOffset = kernelSymbols and kernelSymbols.BOOT_READY_FLAG or nil
	self._readyFlagLinear = readyFlagOffset and (self._kernelLinear + readyFlagOffset) or nil

	self.machine:setBootRecord({
		profile = "x86-bios",
		imageSource = self.image.meta and self.image.meta.source or "external",
		imageProvider = self.image.meta and self.image.meta.provider or "ProtectedModeBringUp",
		imageName = self.image.meta and self.image.meta.name or "ProtectedModeBringUp",
		kernelSectorStart = self.image.layout.kernelSectorStart,
		kernelSectorCount = self.image.layout.kernelSectorCount,
		fsSuperSector = self.image.layout.fsSuperSector,
		rootDirSector = self.image.layout.rootDirSector,
		rootDirSectorCount = self.image.layout.rootDirSectorCount,
		dataStartSector = self.image.layout.dataStartSector,
		fileCount = self.image.layout.fileCount,
		readyFlagLinear = self._readyFlagLinear,
		diagnostics = diagnostics,
	})
	self.machine:_setBootStage("BIOS")
end

function BootController:onDiskRead(startLba, _count, bufferAddress)
	if startLba == 0 and bufferAddress == self._bootLinear then
		self.machine:_setBootStage("BOOT")
	elseif startLba == (self.image.layout.kernelSectorStart - 1) and bufferAddress == self._kernelLinear then
		self.machine:_setBootStage("KERNEL")
	end
end

function BootController:tick(_dt)
	if self.machine:getBootStage() ~= "KERNEL" then
		return
	end
	if self._readyFlagLinear and self.machine.cpu:readPhysical16(self._readyFlagLinear) == 1 then
		self.machine:_setBootStage("RUNNING")
		return
	end
	local pc = self.machine.cpu:getLinearPC()
	if not self._readyFlagLinear and pc >= self._kernelLinear then
		self.machine:_setBootStage("RUNNING")
	end
end

return BootController
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="14">
          <Properties>
            <string name="Name">BootImageCatalog</string>
            <string name="Source"><![CDATA[local Assembler8086 = require(script.Parent.Assembler8086)
local BiosRom = require(script.Parent.BiosRom)

local BootImageCatalog = {}

local function sectorCountForBytes(bytes)
	return math.max(1, math.ceil(#bytes / 512))
end

local function writeChunk(sectors, startLba, bytes)
	local count = sectorCountForBytes(bytes)
	for sectorIndex = 0, count - 1 do
		local sector = {}
		for index = 1, 512 do
			sector[index] = bytes[sectorIndex * 512 + index] or 0
		end
		sectors[startLba + sectorIndex] = sector
	end
	return count
end

local function sectorToCHS(x86, sectorNumber)
	local spt = x86.SECTORS_PER_TRACK or 18
	local heads = x86.HEADS or 1
	local index = math.max(0, (tonumber(sectorNumber) or 1) - 1)
	local trackSize = math.max(1, spt * heads)
	local cylinder = math.floor(index / trackSize)
	local head = math.floor(index / spt) % heads
	local sector = (index % spt) + 1
	return cylinder, head, sector
end

local function encodeCHSWord(x86, sectorNumber)
	local cylinder, _, sector = sectorToCHS(x86, sectorNumber)
	return bit32.bor(
		bit32.lshift(bit32.band(cylinder, 0xFF), 8),
		bit32.lshift(bit32.band(bit32.rshift(cylinder, 8), 0x03), 6),
		bit32.band(sector, 0x3F)
	)
end

local function hex16(value)
	return string.format("0x%04X", (tonumber(value) or 0) % 0x10000)
end

local function descriptorWords(base, access, limit, flags)
	local linear = (tonumber(base) or 0) % 0x100000000
	local segmentLimit = (tonumber(limit) or 0x000FFFFF) % 0x100000
	local baseLow = linear % 0x10000
	local baseMid = math.floor(linear / 0x10000) % 0x100
	local baseHigh = math.floor(linear / 0x1000000) % 0x100
	local limitLow = segmentLimit % 0x10000
	local limitHigh = math.floor(segmentLimit / 0x10000) % 0x10
	local flagsByte = bit32.bor(bit32.lshift((tonumber(flags) or 0x0C) % 0x10, 4), limitHigh)
	return {
		limitLow = limitLow,
		baseLow = baseLow,
		accessBaseMid = (access % 0x100) * 0x100 + baseMid,
		flagsBaseHigh = baseHigh * 0x100 + flagsByte,
	}
end

local function buildProtectedModeMonitorSource()
	return table.concat({
		"PM_ENTRY:",
		"  MOV AX, 0x0010",
		"  MOV DS, AX",
		"  MOV SS, AX",
		"  MOV ESP, 0x00007B00",
		"  MOV AX, 0x0018",
		"  MOV ES, AX",
		"  CALL MONITOR_INIT",
		"PM_LOOP:",
		"  IN AL, 0x60",
		"  CMP AL, 0",
		"  JE PM_LOOP",
		"  CMP AL, 0x80",
		"  JNC PM_LOOP",
		"  CALL TRANSLATE_SCAN",
		"  CMP AL, 0",
		"  JE PM_LOOP",
		"  CALL HANDLE_CHAR",
		"  JMP PM_LOOP",
		"MONITOR_INIT:",
		"  CALL CLEAR_SCREEN",
		"  MOV DWORD [BOOT_READY_FLAG], 1",
		"  MOV ESI, PM_READY_MSG",
		"  CALL PRINT_STRING_PM",
		"  CALL SHOW_PROMPT",
		"  RET",
		"SHOW_PROMPT:",
		"  MOV ESI, PROMPT",
		"  CALL PRINT_STRING_PM",
		"  MOV ESI, COMMAND_BUFFER",
		"  MOV DWORD [COMMAND_LEN], 0",
		"  MOV BYTE [SI], 0",
		"  RET",
		"HANDLE_CHAR:",
		"  CMP AL, 0x08",
		"  JE HANDLE_BACKSPACE",
		"  CMP AL, 0x0A",
		"  JE HANDLE_ENTER",
		"  MOV [INPUT_CHAR], AL",
		"  MOV EAX, [COMMAND_LEN]",
		"  CMP EAX, 63",
		"  JNC HANDLE_CHAR_DONE",
		"  MOV AL, [INPUT_CHAR]",
		"  CALL PUTC",
		"  MOV AL, [INPUT_CHAR]",
		"  MOV [SI], AL",
		"  INC SI",
		"  MOV BYTE [SI], 0",
		"  MOV EAX, [COMMAND_LEN]",
		"  INC EAX",
		"  MOV [COMMAND_LEN], EAX",
		"HANDLE_CHAR_DONE:",
		"  RET",
		"HANDLE_BACKSPACE:",
		"  MOV EAX, [COMMAND_LEN]",
		"  CMP EAX, 0",
		"  JE HANDLE_CHAR_DONE",
		"  DEC SI",
		"  DEC EAX",
		"  MOV [COMMAND_LEN], EAX",
		"  MOV BYTE [SI], 0",
		"  MOV AL, 0x08",
		"  CALL PUTC",
		"  RET",
		"HANDLE_ENTER:",
		"  MOV BYTE [SI], 0",
		"  MOV AL, 0x0A",
		"  CALL PUTC",
		"  CALL EXECUTE_COMMAND",
		"  CALL SHOW_PROMPT",
		"  RET",
		"EXECUTE_COMMAND:",
		"  CMP BYTE [COMMAND_BUFFER], 0",
		"  JE EXECUTE_DONE",
		"CHECK_HELP:",
		"  CMP BYTE [COMMAND_BUFFER], 'h'",
		"  JNE CHECK_CLEAR",
		"  CMP BYTE [COMMAND_BUFFER+1], 'e'",
		"  JNE CHECK_CLEAR",
		"  CMP BYTE [COMMAND_BUFFER+2], 'l'",
		"  JNE CHECK_CLEAR",
		"  CMP BYTE [COMMAND_BUFFER+3], 'p'",
		"  JNE CHECK_CLEAR",
		"  CMP BYTE [COMMAND_BUFFER+4], 0",
		"  JNE CHECK_CLEAR",
		"  CALL CMD_HELP",
		"  RET",
		"CHECK_CLEAR:",
		"  CMP BYTE [COMMAND_BUFFER], 'c'",
		"  JNE CHECK_CLS",
		"  CMP BYTE [COMMAND_BUFFER+1], 'l'",
		"  JNE CHECK_CLS",
		"  CMP BYTE [COMMAND_BUFFER+2], 'e'",
		"  JNE CHECK_CLS",
		"  CMP BYTE [COMMAND_BUFFER+3], 'a'",
		"  JNE CHECK_CLS",
		"  CMP BYTE [COMMAND_BUFFER+4], 'r'",
		"  JNE CHECK_CLS",
		"  CMP BYTE [COMMAND_BUFFER+5], 0",
		"  JNE CHECK_CLS",
		"  CALL CLEAR_SCREEN",
		"  RET",
		"CHECK_CLS:",
		"  CMP BYTE [COMMAND_BUFFER], 'c'",
		"  JNE CHECK_ECHO",
		"  CMP BYTE [COMMAND_BUFFER+1], 'l'",
		"  JNE CHECK_ECHO",
		"  CMP BYTE [COMMAND_BUFFER+2], 's'",
		"  JNE CHECK_ECHO",
		"  CMP BYTE [COMMAND_BUFFER+3], 0",
		"  JNE CHECK_ECHO",
		"  CALL CLEAR_SCREEN",
		"  RET",
		"CHECK_ECHO:",
		"  CMP BYTE [COMMAND_BUFFER], 'e'",
		"  JNE CHECK_UNAME",
		"  CMP BYTE [COMMAND_BUFFER+1], 'c'",
		"  JNE CHECK_UNAME",
		"  CMP BYTE [COMMAND_BUFFER+2], 'h'",
		"  JNE CHECK_UNAME",
		"  CMP BYTE [COMMAND_BUFFER+3], 'o'",
		"  JNE CHECK_UNAME",
		"  CMP BYTE [COMMAND_BUFFER+4], 0",
		"  JE CMD_ECHO_EMPTY",
		"  CMP BYTE [COMMAND_BUFFER+4], ' '",
		"  JNE CHECK_UNAME",
		"  MOV ESI, COMMAND_BUFFER+5",
		"  CALL PRINT_STRING_PM",
		"  MOV ESI, NEWLINE",
		"  CALL PRINT_STRING_PM",
		"  RET",
		"CMD_ECHO_EMPTY:",
		"  MOV ESI, NEWLINE",
		"  CALL PRINT_STRING_PM",
		"  RET",
		"CHECK_UNAME:",
		"  CMP BYTE [COMMAND_BUFFER], 'u'",
		"  JNE CHECK_REBOOT",
		"  CMP BYTE [COMMAND_BUFFER+1], 'n'",
		"  JNE CHECK_REBOOT",
		"  CMP BYTE [COMMAND_BUFFER+2], 'a'",
		"  JNE CHECK_REBOOT",
		"  CMP BYTE [COMMAND_BUFFER+3], 'm'",
		"  JNE CHECK_REBOOT",
		"  CMP BYTE [COMMAND_BUFFER+4], 'e'",
		"  JNE CHECK_REBOOT",
		"  CMP BYTE [COMMAND_BUFFER+5], 0",
		"  JNE CHECK_REBOOT",
		"  MOV ESI, UNAME_MSG",
		"  CALL PRINT_STRING_PM",
		"  RET",
		"CHECK_REBOOT:",
		"  CMP BYTE [COMMAND_BUFFER], 'r'",
		"  JNE CHECK_UNKNOWN",
		"  CMP BYTE [COMMAND_BUFFER+1], 'e'",
		"  JNE CHECK_UNKNOWN",
		"  CMP BYTE [COMMAND_BUFFER+2], 'b'",
		"  JNE CHECK_UNKNOWN",
		"  CMP BYTE [COMMAND_BUFFER+3], 'o'",
		"  JNE CHECK_UNKNOWN",
		"  CMP BYTE [COMMAND_BUFFER+4], 'o'",
		"  JNE CHECK_UNKNOWN",
		"  CMP BYTE [COMMAND_BUFFER+5], 't'",
		"  JNE CHECK_UNKNOWN",
		"  CMP BYTE [COMMAND_BUFFER+6], 0",
		"  JNE CHECK_UNKNOWN",
		"  JMP SOFT_RESET",
		"CHECK_UNKNOWN:",
		"  MOV ESI, UNKNOWN_PREFIX",
		"  CALL PRINT_STRING_PM",
		"  MOV ESI, COMMAND_BUFFER",
		"  CALL PRINT_STRING_PM",
		"  MOV ESI, UNKNOWN_SUFFIX",
