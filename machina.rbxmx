    <Item class="ModuleScript" referent="1">
      <Properties>
        <string name="Name">Config</string>
        <string name="Source"><![CDATA[--Central configuration for the Machina x86 PC emulator.
--PcSystem reads this directly. buildBoardConfig() merges Config.X86 fields
--on top of the defaults below, so X86 values always take precedence.

local Config = {}

Config.EMULATION = {
	PROFILE = "x86-bios",
}

Config.DISPLAY_REFRESH_HZ = 60 

Config.SCREEN_W = 320 
Config.SCREEN_H = 200 
Config.TEXT_COLS = 80
Config.TEXT_ROWS = 25

Config.CHAR_W = 6
Config.CHAR_H = 10 
Config.GLYPH_W = 4
Config.GLYPH_H = 8
Config.PAD_X = 1 
Config.PAD_Y = 1 
Config.FONT_SMOOTHING = false 

--Storage
Config.DISK_BLOCKS = 204800 
Config.DISK_MODEL = "Machina Virtual ATA"

--Memory layout defaults
--These are fallbacks only. Config.X86 overrides all of them at runtime
--via buildBoardConfig(), so edit Config.X86 for actual values.
Config.PAGE_SIZE = 4096

Config.ROM_BASE = 0x000F0000
Config.ROM_SIZE = 0x00010000 

Config.RAM_BASE = 0x00000000
Config.RAM_SIZE = 0x000A0000 

Config.VRAM_BASE = 0x000B8000
Config.VRAM_SIZE = 0x00008000 

--Interrupt controller 
--Defaults before the BIOS programs the PIC. X86 overrides these to the
--real BIOS values (master 0x08 / slave 0x70).
Config.PIC_VECTOR_BASE_MASTER = 0x20
Config.PIC_VECTOR_BASE_SLAVE = 0x28

Config.IRQ = {
	TIMER = 0,
	KEYBOARD = 1,
	COM1 = 4,
	RTC = 8,
	ATA = 14,
}

Config.TIMER = {
	BASE_HZ = 1193182,
	DEFAULT_DIVISOR = 65536, 
}

--I/O port
Config.PORT = {
	PIC_MASTER_CMD = 0x0020,
	PIC_MASTER_DATA = 0x0021,
	PIC_SLAVE_CMD = 0x00A0,
	PIC_SLAVE_DATA = 0x00A1,

	PIT_CHAN0 = 0x0040,
	PIT_CMD = 0x0043,

	KBD_DATA = 0x0060,
	KBD_STATUS = 0x0064,

	RTC_INDEX = 0x0070,
	RTC_DATA = 0x0071,

	VGA_MISC_WRITE = 0x03C2,
	VGA_CRTC_INDEX = 0x03D4,
	VGA_CRTC_DATA = 0x03D5,

	COM1_BASE = 0x03F8,

	IDE_PRIMARY_CMD = 0x01F0,
	IDE_PRIMARY_CTRL = 0x03F6,
}

--x86 BIOS subsystem 
Config.X86 = {
	HEARTBEAT_HZ = Config.DISPLAY_REFRESH_HZ, 
	BOOT_CYCLES_PER_TICK = 1536,
	RUN_CYCLES_PER_TICK = 1024,

	ROM_BASE = 0x000F0000,
	ROM_SIZE = 0x00010000, 

	LOW_RAM_BASE = 0x00000000,
	LOW_RAM_SIZE = 0x000A0000, 

	VIDEO_BASE = 0x000B8000,
	VIDEO_SIZE = 0x00008000, 

	RESET_VECTOR_SEG = 0xF000,
	RESET_VECTOR_OFF = 0xFFF0,
	BIOS_ENTRY_OFFSET = 0x0100, 

	BOOT_DRIVE = 0x80, 
	BOOT_SECTOR_LOAD_SEG = 0x0000,
	BOOT_SECTOR_LOAD_OFF = 0x7C00,
	KERNEL_LOAD_SEG = 0x1000,
	KERNEL_LOAD_OFF = 0x0000,

	SECTORS_PER_TRACK = 18,
	HEADS = 1,

	PIC_VECTOR_BASE_MASTER = 0x08,
	PIC_VECTOR_BASE_SLAVE = 0x70,

	IMAGE = {
		SOURCE = "imported",
		IMPORT_IMAGE = "ProtectedModeBringUp",
	},

	DIAGNOSTICS = {
		ENABLED = true,
		PRINT_SUMMARY = true,
	},
}

return Config
]]></string>
      </Properties>
    </Item>
    <Item class="Folder" referent="2">
      <Properties>
        <string name="Name">net_bridge</string>
      </Properties>
      <Item class="Script" referent="3">
        <Properties>
          <string name="Name">Main</string>
          <token name="RunContext">1</token>
          <string name="Source"><![CDATA[-- Main.server module

local Players = game:GetService("Players")

local NetworkService = require(script.Parent.network.NetworkService)
local HDDStore = require(script.Parent.datastore.HDDStore)

local network = NetworkService.new()
network:start()

local hddStore = HDDStore.new("MachinaHDD-v2")

network.remotes.SaveHDD.OnServerInvoke = function(player, hddSnapshot)
	if type(hddSnapshot) ~= "table" then
		return false, "invalid snapshot"
	end
	return hddStore:saveSnapshot(player, hddSnapshot)
end

network.remotes.LoadHDD.OnServerInvoke = function(player)
	local snapshot, err = hddStore:loadSnapshot(player)
	if not snapshot then
		return nil, err
	end
	return snapshot
end

network.remotes.SyncMachineState.OnServerInvoke = function(player, state)
	if type(state) ~= "table" then
		return false, "invalid state"
	end
	return true
end

Players.PlayerRemoving:Connect(function(player)
	-- Hook point for deferred autosave orchestration
	-- (machines can call SaveHDD proactively before player leaves)
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Folder" referent="4">
        <Properties>
          <string name="Name">datastore</string>
        </Properties>
        <Item class="ModuleScript" referent="5">
          <Properties>
            <string name="Name">HDDStore</string>
            <string name="Source"><![CDATA[-- HDDStore module

local DataStoreService = game:GetService("DataStoreService")
local HttpService = game:GetService("HttpService")

local HDDStore = {}
HDDStore.__index = HDDStore

function HDDStore.new(namespace)
	local self = setmetatable({}, HDDStore)
	self.namespace = namespace or "MachinaHDD-v1"
	self.store = DataStoreService:GetDataStore(self.namespace)
	return self
end

function HDDStore:_keyForPlayer(player)
	return string.format("player:%d:hdd", player.UserId)
end

function HDDStore:saveSnapshot(player, hddImage)
	local key = self:_keyForPlayer(player)
	local payload = {
		updatedAt = os.time(),
		hdd = hddImage,
	}

	local ok, err = pcall(function()
		self.store:SetAsync(key, payload)
	end)
	if not ok then
		return false, tostring(err)
	end

	return true
end

function HDDStore:loadSnapshot(player)
	local key = self:_keyForPlayer(player)
	local ok, result = pcall(function()
		return self.store:GetAsync(key)
	end)

	if not ok then
		return nil, tostring(result)
	end

	return result
end

function HDDStore:encodeSectorDump(sectors)
	return HttpService:JSONEncode(sectors)
end

function HDDStore:decodeSectorDump(raw)
	if type(raw) ~= "string" or raw == "" then
		return {}
	end

	local ok, decoded = pcall(function()
		return HttpService:JSONDecode(raw)
	end)
	if not ok then
		return {}
	end

	return decoded
end

return HDDStore
]]></string>
          </Properties>
        </Item>
      </Item>
      <Item class="Folder" referent="6">
        <Properties>
          <string name="Name">network</string>
        </Properties>
        <Item class="ModuleScript" referent="7">
          <Properties>
            <string name="Name">NetworkService</string>
            <string name="Source"><![CDATA[-- NetworkService module

local ReplicatedStorage = game:GetService("ReplicatedStorage")

local NetworkService = {}
NetworkService.__index = NetworkService

function NetworkService.new()
	local self = setmetatable({}, NetworkService)
	self.folder = nil
	self.remotes = {}
	return self
end

function NetworkService:start()
	local folder = ReplicatedStorage:FindFirstChild("MachinaNet")
	if not folder then
		folder = Instance.new("Folder")
		folder.Name = "MachinaNet"
		folder.Parent = ReplicatedStorage
	end
	self.folder = folder

	self.remotes.SaveHDD = self:_ensureRemote("SaveHDD")
	self.remotes.LoadHDD = self:_ensureRemote("LoadHDD")
	self.remotes.SyncMachineState = self:_ensureRemote("SyncMachineState")

	return true
end

function NetworkService:_ensureRemote(name)
	local remote = self.folder:FindFirstChild(name)
	if not remote then
		remote = Instance.new("RemoteFunction")
		remote.Name = name
		remote.Parent = self.folder
	end
	return remote
end

return NetworkService
]]></string>
          </Properties>
        </Item>
      </Item>
