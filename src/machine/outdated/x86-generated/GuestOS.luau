		"  MOV DI, COMMAND_NAME_BUFFER",
		"  MOV CX, 16",
		"CLEAR_NAME_LOOP:",
		"  MOV BYTE [DI], 0",
		"  INC DI",
		"  DEC CX",
		"  CMP CX, 0",
		"  JNE CLEAR_NAME_LOOP",
		"  MOV SI, " .. hex16(commandBufferOffset),
		"SKIP_CMD_SPACES:",
