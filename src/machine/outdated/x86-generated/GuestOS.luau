		"  JNE LOAD_FILESYSTEM_DONE",
		"  INC SI",
		"  MOV AL, [SI]",
		"  CMP AL, " .. hex8(string.byte(fsMagic, 2)),
		"  JNE LOAD_FILESYSTEM_DONE",
