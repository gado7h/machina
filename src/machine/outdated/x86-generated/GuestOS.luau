		"  CMP AL, 32",
		"  JNE COPY_CMD_START",
		"  INC SI",
		"  JMP SKIP_CMD_SPACES",
		"COPY_CMD_START:",
		"  MOV DI, COMMAND_NAME_BUFFER",
		"  MOV BX, 0",
		"COPY_CMD_LOOP:",
		"  MOV AL, [SI]",
		"  CMP AL, 0",
		"  JE COPY_CMD_DONE",
		"  CMP AL, 32",
		"  JE COPY_CMD_DONE",
		"  MOV [DI], AL",
		"  INC DI",
		"  INC SI",
		"  INC BX",
		"  CMP BX, 15",
		"  JC COPY_CMD_LOOP",
		"COPY_CMD_DONE:",
		"  MOV BYTE [DI], 0",
		"SKIP_TAIL_SPACES:",
		"  MOV AL, [SI]",
		"  CMP AL, 32",
		"  JNE COPY_TAIL_START",
		"  INC SI",
		"  JMP SKIP_TAIL_SPACES",
		"COPY_TAIL_START:",
		"  MOV DI, " .. hex16(commandTailOffset),
		"COPY_TAIL_LOOP:",
		"  MOV AL, [SI]",
		"  MOV [DI], AL",
		"  CMP AL, 0",
		"  JE COPY_TAIL_DONE",
		"  INC SI",
		"  INC DI",
		"  JMP COPY_TAIL_LOOP",
		"COPY_TAIL_DONE:",
		"  RET",
		"",
		"READ_LINE_TO_BUFFER:",
		"  PUSH BX",
