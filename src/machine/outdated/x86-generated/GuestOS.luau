		"  CMP AL, " .. hex8(0x01),
		"  JNE VALIDATE_EXECUTABLE_DONE",
		"  MOV BX, " .. hex16(programStageOffset + 6),
		"  MOV AX, [BX]",
		"  CMP AX, " .. hex16(execHeaderSize),
		"  JNE VALIDATE_EXECUTABLE_DONE",
		"  MOV BX, " .. hex16(programStageOffset + 8),
		"  MOV AX, [BX]",
		"  MOV WORD [CURRENT_EXEC_LOAD], AX",
		"  MOV BX, " .. hex16(programStageOffset + 10),
		"  MOV AX, [BX]",
		"  MOV WORD [CURRENT_EXEC_ENTRY], AX",
		"  MOV BX, " .. hex16(programStageOffset + 12),
		"  MOV AX, [BX]",
		"  MOV WORD [CURRENT_EXEC_SIZE], AX",
		"  ADD AX, " .. hex16(execHeaderSize),
		"  CMP AX, [CURRENT_FILE_SIZE]",
		"  JNE VALIDATE_EXECUTABLE_DONE",
		"  MOV WORD [CURRENT_EXEC_VALID], 1",
		"VALIDATE_EXECUTABLE_DONE:",
		"  RET",
		"",
		"LOAD_EXECUTABLE_IMAGE:",
		"  MOV SI, " .. hex16(programStageOffset + execHeaderSize),
		"  MOV DI, [CURRENT_EXEC_LOAD]",
		"  MOV CX, [CURRENT_EXEC_SIZE]",
		"LOAD_EXECUTABLE_LOOP:",
		"  CMP CX, 0",
		"  JE LOAD_EXECUTABLE_DONE",
		"  MOV AL, [SI]",
		"  MOV [DI], AL",
		"  INC SI",
		"  INC DI",
		"  DEC CX",
		"  JMP LOAD_EXECUTABLE_LOOP",
		"LOAD_EXECUTABLE_DONE:",
		"  RET",
		"",
		"EXECUTE_LOOKUP_NAME:",
		"  CALL FIND_ENTRY",
		"  CMP AL, 1",
		"  JNE COMMAND_NOT_FOUND",
		"  MOV SI, BX",
		"  ADD SI, 11",
		"  MOV AL, [SI]",
		"  CMP AL, " .. hex8(0x81),
		"  JNE COMMAND_NOT_EXECUTABLE",
		"  CALL LOAD_ENTRY_DATA",
		"  JC COMMAND_LOAD_FAIL",
		"  CALL VALIDATE_EXECUTABLE",
		"  MOV AX, [CURRENT_EXEC_VALID]",
		"  CMP AX, 1",
		"  JNE COMMAND_LOAD_FAIL",
		"  CALL LOAD_EXECUTABLE_IMAGE",
		"  MOV BX, [CURRENT_EXEC_ENTRY]",
		"  CALL BX",
		"  RET",
		"RUN_COMMAND:",
		"  MOV SI, COMMAND_NAME_BUFFER",
		"  CALL BUILD_LOOKUP_NAME",
		"  CALL EXECUTE_LOOKUP_NAME",
		"  RET",
		"COMMAND_NOT_EXECUTABLE:",
		"  MOV SI, COMMAND_NOT_EXEC_TEXT",
		"  CALL PRINT_STRING",
		"  RET",
		"COMMAND_NOT_FOUND:",
		"  MOV SI, COMMAND_NOT_FOUND_TEXT",
		"  CALL PRINT_STRING",
		"  RET",
		"COMMAND_LOAD_FAIL:",
		"  MOV SI, COMMAND_LOAD_FAIL_TEXT",
		"  CALL PRINT_STRING",
		"  RET",
		"",
		"INT60_HANDLER:",
		"  PUSH AX",
		"  PUSH BX",
		"  PUSH CX",
		"  PUSH DX",
		"  PUSH SI",
		"  PUSH DI",
		"  CMP AH, 0x01",
		"  JNE CHECK_SYSCALL_READLINE",
		"  CALL PRINT_STRING",
		"  JMP INT60_DONE",
		"CHECK_SYSCALL_READLINE:",
		"  CMP AH, 0x02",
		"  JNE CHECK_SYSCALL_EXEC",
		"  CALL READ_LINE_TO_BUFFER",
		"  JMP INT60_DONE",
		"CHECK_SYSCALL_EXEC:",
		"  CMP AH, 0x03",
		"  JNE CHECK_HELP",
		"  CALL EXEC_COMMAND_LINE",
		"  JMP INT60_DONE",
		"CHECK_HELP:",
		"  CMP AH, 0x10",
		"  JNE CHECK_LS",
		"  CALL SERVICE_HELP",
		"  JMP INT60_DONE",
		"CHECK_LS:",
		"  CMP AH, 0x11",
		"  JNE CHECK_PS",
		"  CALL SERVICE_LS",
		"  JMP INT60_DONE",
		"CHECK_PS:",
		"  CMP AH, 0x12",
		"  JNE CHECK_ECHO",
		"  CALL SERVICE_PS",
		"  JMP INT60_DONE",
		"CHECK_ECHO:",
		"  CMP AH, 0x13",
		"  JNE CHECK_CLEAR",
		"  CALL SERVICE_ECHO",
		"  JMP INT60_DONE",
		"CHECK_CLEAR:",
		"  CMP AH, 0x14",
		"  JNE CHECK_VER",
		"  CALL CLEAR_SCREEN",
		"  JMP INT60_DONE",
		"CHECK_VER:",
		"  CMP AH, 0x15",
		"  JNE CHECK_WHOAMI",
		"  CALL SERVICE_VER",
		"  JMP INT60_DONE",
		"CHECK_WHOAMI:",
		"  CMP AH, 0x16",
		"  JNE CHECK_REBOOT",
		"  CALL SERVICE_WHOAMI",
		"  JMP INT60_DONE",
		"CHECK_REBOOT:",
		"  CMP AH, 0x17",
		"  JNE CHECK_CAT",
		"  INT 0x19",
		"  JMP INT60_DONE",
		"CHECK_CAT:",
		"  CMP AH, 0x18",
		"  JNE INT60_DONE",
		"  CALL SERVICE_CAT",
		"INT60_DONE:",
		"  POP DI",
		"  POP SI",
		"  POP DX",
		"  POP CX",
		"  POP BX",
		"  POP AX",
		"  IRET",
		"",
		"SERVICE_HELP:",
		"  MOV SI, HELP_TEXT",
		"  CALL PRINT_STRING",
		"  RET",
		"",
		"SERVICE_LS:",
		"  MOV BX, " .. hex16(rootDirBufferOffset),
		"  MOV CX, [FS_FILE_COUNT]",
		"LS_LOOP:",
		"  CMP CX, 0",
		"  JE LS_DONE",
		"  MOV DI, BX",
		"  CALL PRINT_ENTRY_NAME",
		"  ADD BX, " .. hex16(fsEntrySize),
		"  DEC CX",
		"  JMP LS_LOOP",
		"LS_DONE:",
		"  RET",
		"",
		"PRINT_ENTRY_NAME:",
		"  MOV SI, DI",
		"PRINT_ENTRY_LOOP:",
		"  MOV AL, [SI]",
		"  CMP AL, 32",
		"  JE PRINT_ENTRY_DONE",
		"  CMP AL, 0",
		"  JE PRINT_ENTRY_DONE",
		"  MOV AH, 0x0E",
		"  INT 0x10",
		"  INC SI",
		"  JMP PRINT_ENTRY_LOOP",
		"PRINT_ENTRY_DONE:",
		"  CALL PRINT_CRLF",
		"  RET",
		"",
		"SERVICE_PS:",
		"  MOV SI, PS_TEXT",
		"  CALL PRINT_STRING",
		"  RET",
		"",
		"SERVICE_ECHO:",
		"  MOV SI, " .. hex16(commandTailOffset),
		"  CALL PRINT_STRING",
		"  CALL PRINT_CRLF",
		"  RET",
		"",
		"SERVICE_VER:",
		"  MOV SI, VER_TEXT",
		"  CALL PRINT_STRING",
		"  RET",
		"",
		"SERVICE_WHOAMI:",
		"  MOV SI, WHOAMI_TEXT",
		"  CALL PRINT_STRING",
		"  RET",
		"",
		"SERVICE_CAT:",
		"  MOV SI, " .. hex16(commandTailOffset),
		"  MOV AL, [SI]",
		"  CMP AL, 0",
		"  JE CAT_USAGE",
		"  CALL BUILD_LOOKUP_NAME",
		"  CALL FIND_ENTRY",
		"  CMP AL, 1",
		"  JNE CAT_NOT_FOUND",
		"  MOV SI, BX",
		"  ADD SI, 11",
		"  MOV AL, [SI]",
		"  CMP AL, " .. hex8(0x81),
		"  JE CAT_BINARY_FILE",
		"  CALL LOAD_ENTRY_DATA",
		"  JC CAT_READ_FAIL",
		"  MOV SI, " .. hex16(programStageOffset),
		"  MOV CX, [CURRENT_FILE_SIZE]",
		"CAT_PRINT_LOOP:",
		"  CMP CX, 0",
		"  JE CAT_DONE",
		"  MOV AL, [SI]",
		"  MOV AH, 0x0E",
		"  INT 0x10",
		"  INC SI",
		"  DEC CX",
		"  JMP CAT_PRINT_LOOP",
		"CAT_DONE:",
		"  CALL PRINT_CRLF",
		"  RET",
		"CAT_USAGE:",
		"  MOV SI, CAT_USAGE_TEXT",
		"  CALL PRINT_STRING",
		"  RET",
		"CAT_NOT_FOUND:",
		"  MOV SI, FILE_NOT_FOUND_TEXT",
		"  CALL PRINT_STRING",
		"  RET",
		"CAT_BINARY_FILE:",
		"  MOV SI, CAT_BINARY_TEXT",
		"  CALL PRINT_STRING",
		"  RET",
		"CAT_READ_FAIL:",
		"  MOV SI, COMMAND_LOAD_FAIL_TEXT",
		"  CALL PRINT_STRING",
		"  RET",
		"",
		"SET_DISK_ADDRESS:",
		"  PUSH AX",
		"  PUSH BX",
		"  MOV BX, AX",
		"  SUB BX, 1",
		"  MOV CX, 0",
		"  MOV DH, 0",
		"SET_DISK_ADDRESS_LOOP:",
		"  CMP BX, " .. hex16(x86.SECTORS_PER_TRACK or 18),
		"  JC SET_DISK_ADDRESS_DONE",
		"  SUB BX, " .. hex16(x86.SECTORS_PER_TRACK or 18),
		"  ADD DX, 0x0100",
		"  CMP DH, " .. hex8((x86.HEADS or 1) % 0x100),
		"  JC SET_DISK_ADDRESS_LOOP",
		"  MOV DH, 0",
		"  ADD CX, 0x0100",
		"  JMP SET_DISK_ADDRESS_LOOP",
		"SET_DISK_ADDRESS_DONE:",
		"  MOV AX, BX",
		"  ADD AX, 1",
		"  MOV CL, AL",
		"  POP BX",
		"  POP AX",
		"  RET",
		"",
		"BOOT_READY_FLAG:",
		"  DW 0",
		"FS_MOUNTED:",
		"  DW 0",
		"FS_ROOT_DIR_SECTOR:",
		"  DW 0",
		"FS_ROOT_DIR_COUNT:",
		"  DW 0",
		"FS_FILE_COUNT:",
		"  DW 0",
		"CURRENT_FILE_SECTOR:",
		"  DW 0",
		"CURRENT_FILE_COUNT:",
		"  DW 0",
		"CURRENT_FILE_SIZE:",
		"  DW 0",
		"CURRENT_EXEC_LOAD:",
		"  DW 0",
		"CURRENT_EXEC_ENTRY:",
		"  DW 0",
		"CURRENT_EXEC_SIZE:",
		"  DW 0",
		"CURRENT_EXEC_VALID:",
		"  DW 0",
		"SHELL_FILE_NAME:",
		'  DB "shell", 0',
		"SHELL_EXIT_TEXT:",
		'  DB "Shell exited", 13, 10, 0',
		"COMMAND_NAME_BUFFER:",
		'  DB "                ", 0',
		"LOOKUP_NAME:",
		'  DB "           ", 0',
		"KERNEL_BANNER:",
		'  DB "NovaOS x86 kernel", 13, 10, 0',
		"FS_MOUNT_FAIL_TEXT:",
		'  DB "NXFS mount failed", 13, 10, 0',
		"COMMAND_NOT_FOUND_TEXT:",
		'  DB "Bad command or file name", 13, 10, 0',
		"COMMAND_NOT_EXEC_TEXT:",
		'  DB "File is not executable", 13, 10, 0',
		"COMMAND_LOAD_FAIL_TEXT:",
		'  DB "Program load failed", 13, 10, 0',
		"FILE_NOT_FOUND_TEXT:",
		'  DB "File not found", 13, 10, 0',
		"CAT_USAGE_TEXT:",
		'  DB "usage: cat <file>", 13, 10, 0',
		"CAT_BINARY_TEXT:",
		'  DB "Binary executable file", 13, 10, 0',
		"HELP_TEXT:",
		'  DB "Commands: help ls ps echo clear ver whoami reboot cat", 13, 10, "Try: cat readme.txt", 13, 10, 0',
		"PS_TEXT:",
		'  DB "PID  TASK", 13, 10, "1    kernel", 13, 10, "2    command", 13, 10, 0',
		"VER_TEXT:",
		'  DB "NovaOS/x86 0.2", 13, 10, 0',
		"WHOAMI_TEXT:",
		'  DB "root", 13, 10, 0',
	}

	local kernel = table.concat(kernelLines, "\n")

	local programs = {}
	for _, spec in ipairs(PROGRAMS) do
		if spec.loadKind == "shell" then
			programs[spec.command] = buildShellSource(shellLoadOffset, lineBufferSize)
		else
			programs[spec.command] = buildExecutableSource(spec, programLoadOffset)
		end
	end

	return {
		bios = bios,
		bootSector = bootSector,
		kernel = kernel,
		programs = programs,
	}
end

return GuestOS
