		"  RET",
		"",
		"PRINT_STRING:",
		"  MOV AL, [SI]",
		"  CMP AL, 0",
		"  JE PRINT_STRING_DONE",
		"  MOV AH, 0x0E",
		"  INT 0x10",
		"  INC SI",
		"  JMP PRINT_STRING",
		"PRINT_STRING_DONE:",
		"  RET",
		"",
		"PRINT_CRLF:",
		"  MOV AX, 0x0E0D",
