local GuestOS = {}

local PROGRAMS = {
	{ command = "shell", fileName = "shell", loadKind = "shell" },
	{ command = "help", fileName = "help", service = 0x10 },
	{ command = "ls", fileName = "ls", service = 0x11 },
	{ command = "ps", fileName = "ps", service = 0x12 },
	{ command = "echo", fileName = "echo", service = 0x13 },
	{ command = "clear", fileName = "clear", service = 0x14 },
	{ command = "ver", fileName = "ver", service = 0x15 },
	{ command = "whoami", fileName = "whoami", service = 0x16 },
	{ command = "reboot", fileName = "reboot", service = 0x17 },
	{ command = "cat", fileName = "cat", service = 0x18 },
}

local DATA_FILES = {
	{
		name = "readme.txt",
		content = "Nova x86 filesystem image.\r\nUse ls to inspect files.\r\nUse cat readme.txt to read this file.\r\n",
	},
}

local function hex16(value)
	return string.format("0x%04X", (tonumber(value) or 0) % 0x10000)
end

local function hex8(value)
	return string.format("0x%02X", (tonumber(value) or 0) % 0x100)
end

local function sectorToCHS(x86, sectorNumber)
	local spt = x86.SECTORS_PER_TRACK or 18
	local heads = x86.HEADS or 1
	local index = math.max(0, (tonumber(sectorNumber) or 1) - 1)
	local trackSize = math.max(1, spt * heads)
	local cylinder = math.floor(index / trackSize)
	local head = math.floor(index / spt) % heads
	local sector = (index % spt) + 1
	return cylinder, head, sector
end

local function encodeCHSWord(x86, sectorNumber)
	local cylinder, _, sector = sectorToCHS(x86, sectorNumber)
	return bit32.bor(
		bit32.lshift(bit32.band(cylinder, 0xFF), 8),
		bit32.lshift(bit32.band(bit32.rshift(cylinder, 8), 0x03), 6),
		bit32.band(sector, 0x3F)
	)
end

function GuestOS.programs()
	local out = {}
	for _, spec in ipairs(PROGRAMS) do
		out[#out + 1] = {
			command = spec.command,
			fileName = spec.fileName,
			service = spec.service,
			loadKind = spec.loadKind or "program",
		}
	end
	return out
end

function GuestOS.files()
	local out = {}
	for _, spec in ipairs(DATA_FILES) do
		out[#out + 1] = {
			name = spec.name,
			content = spec.content,
		}
	end
	return out
end

local function zeroBytes(count)
	local out = {}
	for _ = 1, count do
		out[#out + 1] = "0"
	end
	return table.concat(out, ", ")
end

local function buildShellSource(shellLoadOffset, lineBufferSize)
	return table.concat({
		"ORG " .. hex16(shellLoadOffset),
		"START:",
		"SHELL_LOOP:",
		"  MOV SI, SHELL_PROMPT",
		"  MOV AH, 0x01",
		"  INT 0x60",
		"  MOV DI, SHELL_INPUT_BUFFER",
		"  MOV CX, " .. hex16(lineBufferSize),
		"  MOV AH, 0x02",
		"  INT 0x60",
		"  MOV SI, SHELL_INPUT_BUFFER",
		"  MOV AL, [SI]",
		"  CMP AL, 0",
		"  JE SHELL_LOOP",
		"  MOV AH, 0x03",
		"  INT 0x60",
		"  JMP SHELL_LOOP",
		"SHELL_PROMPT:",
		'  DB "A:\\>", 0',
		"SHELL_INPUT_BUFFER:",
		"  DB " .. zeroBytes(lineBufferSize),
	}, "\n")
end

local function buildExecutableSource(spec, loadOffset)
	return table.concat({
		"ORG " .. hex16(loadOffset),
		"START:",
		"  MOV AH, " .. hex8(spec.service),
		"  INT 0x60",
		"  RET",
	}, "\n")
end

