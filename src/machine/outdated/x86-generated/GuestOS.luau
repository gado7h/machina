	local shellLoadOffset = x86.SHELL_LOAD_OFFSET or 0x9000
	local commandBufferOffset = x86.COMMAND_BUFFER_OFFSET or 0x7200
	local commandTailOffset = x86.COMMAND_TAIL_OFFSET or 0x7280
	local lineBufferSize = x86.LINE_BUFFER_SIZE or 96
	local bootDrive = x86.BOOT_DRIVE or 0x80
	local kernelCHS = encodeCHSWord(x86, layout.kernelSectorStart or 2)
	local _, kernelHead = sectorToCHS(x86, layout.kernelSectorStart or 2)
	local fsSuperSector = layout.fsSuperSector or 3
	local fsEntrySize = x86.FS_ENTRY_SIZE or 32
	local execHeaderSize = x86.EXEC_HEADER_SIZE or 32
	local fsVersion = x86.FS_VERSION or 1
	local fsBlockSize = config.DISK_BLOCK_SIZE or 512
	local fsMagic = x86.FS_MAGIC or "NXFS"
	local execMagic = x86.EXEC_MAGIC or "NX16"
	local execVersion = x86.EXEC_VERSION or 1

	local bios = table.concat({
		"ORG 0x0100",
		"START:",
		"  CLI",
		"  XOR AX, AX",
		"  MOV ES, AX",
		"  MOV SS, AX",
		"  MOV SP, 0x7C00",
		"  MOV AX, 0xF000",
		"  MOV DS, AX",
		"  MOV AX, 0x0003",
		"  INT 0x10",
		"  MOV SI, BIOS_BANNER",
		"  CALL PRINT_STRING",
		"  MOV AX, 0x0000",
		"  MOV DS, AX",
		"  MOV ES, AX",
		"  MOV BX, 0x7C00",
		"  MOV AX, 0x0201",
		"  MOV CX, 0x0001",
		"  MOV DX, " .. hex16(bootDrive),
		"  INT 0x13",
		"  JC BOOT_FAIL",
		"  PUSH 0x0000",
		"  PUSH 0x7C00",
		"  RETF",
		"",
		"BOOT_FAIL:",
		"  MOV AX, 0xF000",
		"  MOV DS, AX",
		"  MOV SI, BOOT_FAIL_MSG",
		"  CALL PRINT_STRING",
		"BOOT_HANG:",
		"  HLT",
		"  JMP BOOT_HANG",
		"",
		"PRINT_STRING:",
		"  MOV AL, [SI]",
		"  CMP AL, 0",
		"  JE PRINT_DONE",
		"  MOV AH, 0x0E",
		"  INT 0x10",
		"  INC SI",
		"  JMP PRINT_STRING",
		"PRINT_DONE:",
		"  RET",
		"",
		"BIOS_BANNER:",
		'  DB "Nova x86 BIOS", 13, 10, 0',
		"BOOT_FAIL_MSG:",
		'  DB "Boot failed", 13, 10, 0',
	}, "\n")

	local bootSector = table.concat({
		"ORG 0x7C00",
		"START:",
		"  CLI",
		"  XOR AX, AX",
		"  MOV DS, AX",
		"  MOV SS, AX",
		"  MOV SP, 0x7C00",
		"  MOV [BOOT_DRIVE], DL",
		"  MOV SI, BOOT_MSG",
		"  CALL PRINT_STRING",
		"  MOV AX, " .. hex16(kernelLoadSegment),
		"  MOV ES, AX",
		"  MOV BX, 0x0000",
		"  MOV AX, " .. hex16(bit32.bor(0x0200, layout.kernelSectorCount or 1)),
		"  MOV CX, " .. hex16(kernelCHS),
		"  MOV DX, " .. hex16(bit32.bor(bootDrive, bit32.lshift(kernelHead, 8))),
		"  MOV DL, [BOOT_DRIVE]",
		"  INT 0x13",
		"  JC LOAD_FAIL",
		"  PUSH " .. hex16(kernelLoadSegment),
		"  PUSH 0x0000",
		"  RETF",
		"",
		"LOAD_FAIL:",
		"  MOV SI, LOAD_FAIL_MSG",
		"  CALL PRINT_STRING",
		"LOAD_HANG:",
		"  HLT",
		"  JMP LOAD_HANG",
		"",
		"PRINT_STRING:",
		"  MOV AL, [SI]",
		"  CMP AL, 0",
		"  JE PRINT_DONE",
		"  MOV AH, 0x0E",
		"  INT 0x10",
		"  INC SI",
		"  JMP PRINT_STRING",
		"PRINT_DONE:",
		"  RET",
		"",
		"BOOT_DRIVE:",
		"  DB 0",
